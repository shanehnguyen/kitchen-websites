---
/* FeaturedVideo — the click-to-play featured video (the VSL). Self-contained:
   markup, lazy click-to-play script, and styles travel together. The source is
   fetched only on first click, so it never costs a visitor a download until they
   ask for it, then it hands off to native controls. Same treatment as the
   homepage reel; reused wherever the video should appear. */
interface Props {
  src: string;
  poster: string;
  class?: string;
}
const { src, poster, class: className } = Astro.props;
---
<div class:list={['reel-video', className]}>
  <video class="reel-video__media" playsinline preload="metadata" poster={poster} data-src={src}></video>
  <button type="button" class="reel-video__play" aria-label="Play video"><span aria-hidden="true">▶</span></button>
</div>

<script>
  // Wire every featured video on the page (guarded so it's only wired once).
  document.querySelectorAll<HTMLElement>('.reel-video').forEach((reel) => {
    if (reel.dataset.wired) return;
    const vid = reel.querySelector<HTMLVideoElement>('.reel-video__media');
    const btn = reel.querySelector<HTMLButtonElement>('.reel-video__play');
    if (!vid || !btn) return;
    reel.dataset.wired = '1';
    btn.addEventListener('click', () => {
      const s = vid.getAttribute('data-src');
      if (s && !vid.getAttribute('src')) vid.src = s;
      vid.controls = true;
      reel.classList.add('is-playing');
      vid.play().catch(() => {});
    });
  });
</script>

<style>
  .reel-video {
    position: relative; aspect-ratio: 16 / 9; width: 100%; max-width: 68rem; margin-inline: auto;
    background: var(--cabinet); border: var(--rule-thick) solid var(--cabinet); border-radius: var(--radius-md);
    box-shadow: 0 32px 60px -24px rgba(18, 16, 12, 0.55);
    display: flex; align-items: center; justify-content: center; overflow: hidden;
  }
  .reel-video__media { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center; background: var(--cabinet); }
  .reel-video::after {
    content: "Video"; position: absolute; bottom: var(--space-3); right: var(--space-4);
    font-family: var(--font-mono); font-size: var(--fs-small); letter-spacing: var(--tracking-caps);
    text-transform: uppercase; color: var(--paper-50); pointer-events: none;
  }
  .reel-video.is-playing::after { display: none; }
  .reel-video.is-playing .reel-video__play { display: none; }
  .reel-video__play {
    position: relative; z-index: 1;
    width: 84px; height: 84px; border-radius: 50%;
    border: 2px solid var(--porcelain); background: color-mix(in srgb, var(--porcelain) 12%, transparent);
    color: var(--porcelain); font-size: 1.6rem; line-height: 1; padding-left: 5px;
    display: flex; align-items: center; justify-content: center;
    transition: transform var(--duration-fast) var(--ease-out), background var(--duration-fast) var(--ease-out);
  }
  .reel-video__play:hover { transform: scale(1.06); background: color-mix(in srgb, var(--porcelain) 22%, transparent); }
</style>
