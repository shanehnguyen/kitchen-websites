---
/* FeaturedVideo — the featured video (the VSL). Self-contained: markup, script,
   and styles travel together. Two modes:
   • default (click-to-play): source is fetched only on first click, so it never
     costs a visitor a download until they ask for it.
   • autoplay: loads immediately and autoplays MUTED with a big "Tap for sound"
     unmute button (VSL pattern). Unmuting restarts from the top so they hear the
     whole message with sound. Same component reused wherever a video appears. */
interface Props {
  src: string;
  poster: string;
  class?: string;
  /* optional prompt shown beneath the play button (click-to-play mode only). */
  playLabel?: string;
  /* autoplay muted with a big unmute button (the VSL treatment). */
  autoplay?: boolean;
}
const { src, poster, class: className, playLabel, autoplay = false } = Astro.props;
---
<div class:list={['reel-video', className, { 'reel-video--auto': autoplay }]} data-autoplay={autoplay ? '1' : undefined}>
  <video
    class="reel-video__media"
    playsinline
    poster={poster}
    preload={autoplay ? 'auto' : 'metadata'}
    autoplay={autoplay}
    muted={autoplay}
    src={autoplay ? src : undefined}
    data-src={src}
    controlslist="nodownload noplaybackrate noremoteplayback"
    disablepictureinpicture
  ></video>
  {autoplay ? (
    <>
      <button type="button" class="reel-video__unmute" aria-label="Tap for sound">
        <span class="reel-video__unmute-icon" aria-hidden="true">🔇</span>
        <span class="reel-video__unmute-text">Tap for sound</span>
      </button>
      <span class="reel-video__resume" aria-hidden="true">▶</span>
    </>
  ) : (
    <div class="reel-video__cue">
      <button type="button" class="reel-video__play" aria-label={playLabel || 'Play video'}><span aria-hidden="true">▶</span></button>
      {playLabel && <span class="reel-video__hint" role="button" tabindex="0">{playLabel}</span>}
    </div>
  )}
</div>

<script>
  // Wire every featured video on the page (guarded so it's only wired once).
  document.querySelectorAll<HTMLElement>('.reel-video').forEach((reel) => {
    if (reel.dataset.wired) return;
    const vid = reel.querySelector<HTMLVideoElement>('.reel-video__media');
    if (!vid) return;
    reel.dataset.wired = '1';

    // ---- autoplay-muted mode: locked VSL player ----
    // No native controls (no volume, no scrub bar, no skip-forward, no PiP, no
    // download). Just autoplay muted → tap for sound, then tap to play/pause.
    if (reel.dataset.autoplay) {
      const unmute = reel.querySelector<HTMLButtonElement>('.reel-video__unmute');
      vid.muted = true;
      vid.play().catch(() => { /* autoplay blocked; tapping starts it */ });

      // never expose native controls
      vid.controls = false;
      vid.addEventListener('contextmenu', (e) => e.preventDefault()); // no right-click download

      // anti-skip: they can never jump ahead of what they've actually watched
      let maxWatched = 0;
      vid.addEventListener('timeupdate', () => { if (!vid.seeking) maxWatched = Math.max(maxWatched, vid.currentTime); });
      vid.addEventListener('seeking', () => { if (vid.currentTime > maxWatched + 0.4) vid.currentTime = maxWatched; });

      const doUnmute = () => {
        vid.muted = false;
        vid.currentTime = 0;   // restart so they hear the full message with sound
        maxWatched = 0;
        reel.classList.add('is-unmuted');
        vid.play().catch(() => {});
      };
      if (unmute) unmute.addEventListener('click', (e) => { e.stopPropagation(); doUnmute(); });

      // tap the video: turn sound on first, then it toggles play/pause
      vid.addEventListener('click', () => {
        if (!reel.classList.contains('is-unmuted')) { doUnmute(); return; }
        if (vid.paused) vid.play().catch(() => {}); else vid.pause();
      });
      vid.addEventListener('pause', () => reel.classList.add('is-paused'));
      vid.addEventListener('play', () => reel.classList.remove('is-paused'));
      return;
    }

    // ---- default click-to-play mode ----
    const btn = reel.querySelector<HTMLButtonElement>('.reel-video__play');
    if (!btn) return;
    const play = () => {
      const s = vid.getAttribute('data-src');
      if (s && !vid.getAttribute('src')) vid.src = s;
      vid.controls = true;
      reel.classList.add('is-playing');
      vid.play().catch(() => {});
    };
    btn.addEventListener('click', play);
    // the text prompt (if present) plays too
    const hint = reel.querySelector<HTMLElement>('.reel-video__hint');
    if (hint) {
      hint.addEventListener('click', play);
      hint.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); play(); } });
    }
  });
</script>

<style>
  .reel-video {
    position: relative; aspect-ratio: 16 / 9; width: 100%; max-width: 68rem; margin-inline: auto;
    background: var(--cabinet); border: var(--rule-thick) solid var(--cabinet); border-radius: var(--radius-md);
    box-shadow: 0 32px 60px -24px rgba(18, 16, 12, 0.55);
    display: flex; align-items: center; justify-content: center; overflow: hidden;
  }
  .reel-video__media { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center; background: var(--cabinet); }
  .reel-video::after {
    content: "Video"; position: absolute; bottom: var(--space-3); right: var(--space-4);
    font-family: var(--font-mono); font-size: var(--fs-small); letter-spacing: var(--tracking-caps);
    text-transform: uppercase; color: var(--paper-50); pointer-events: none;
  }
  .reel-video.is-playing::after,
  .reel-video--auto::after { display: none; }
  .reel-video.is-playing .reel-video__cue { display: none; }

  /* play button + optional text prompt, stacked and centered over the poster */
  .reel-video__cue { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center; gap: var(--space-4); }
  .reel-video__hint {
    font-family: var(--font-body); font-weight: var(--fw-body-semi);
    font-size: var(--fs-body); letter-spacing: 0.01em;
    color: var(--porcelain); cursor: pointer; text-align: center;
    padding: var(--space-2) var(--space-4); border-radius: var(--radius-pill, 999px);
    background: color-mix(in srgb, var(--cabinet) 55%, transparent);
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.5);
    transition: background var(--duration-fast) var(--ease-out);
  }
  .reel-video__hint:hover { background: color-mix(in srgb, var(--cabinet) 75%, transparent); }
  .reel-video__play {
    position: relative; z-index: 1;
    width: 84px; height: 84px; border-radius: 50%;
    border: 2px solid var(--porcelain); background: color-mix(in srgb, var(--porcelain) 12%, transparent);
    color: var(--porcelain); font-size: 1.6rem; line-height: 1; padding-left: 5px;
    display: flex; align-items: center; justify-content: center;
    transition: transform var(--duration-fast) var(--ease-out), background var(--duration-fast) var(--ease-out);
  }
  .reel-video__play:hover { transform: scale(1.06); background: color-mix(in srgb, var(--porcelain) 22%, transparent); }

  /* big "tap for sound" unmute button (autoplay mode). Sits over the video while
     it plays muted; vanishes once the visitor turns sound on. */
  .reel-video__unmute {
    position: absolute; z-index: 2; inset: auto auto var(--space-5) 50%; transform: translateX(-50%);
    display: inline-flex; align-items: center; gap: var(--space-3);
    padding: var(--space-3) var(--space-5); border-radius: var(--radius-pill, 999px);
    border: 2px solid var(--porcelain);
    background: color-mix(in srgb, var(--cabinet) 78%, transparent);
    color: var(--porcelain); cursor: pointer;
    font-family: var(--font-body); font-weight: var(--fw-body-bold);
    font-size: var(--fs-bodyL); letter-spacing: 0.01em; line-height: 1;
    box-shadow: 0 10px 30px -8px rgba(0, 0, 0, 0.6);
    animation: reel-unmute-pulse 2.2s var(--ease-out) infinite;
    transition: transform var(--duration-fast) var(--ease-out), background var(--duration-fast) var(--ease-out);
  }
  .reel-video__unmute:hover { transform: translateX(-50%) scale(1.04); background: color-mix(in srgb, var(--cabinet) 90%, transparent); animation: none; }
  .reel-video__unmute-icon { font-size: 1.3em; line-height: 1; }
  .reel-video.is-unmuted .reel-video__unmute { display: none; }

  /* locked player: tap the frame to play/pause; a ▶ shows only while paused */
  .reel-video--auto .reel-video__media { cursor: pointer; }
  .reel-video__resume {
    position: absolute; inset: 0; margin: auto; z-index: 2;
    width: 84px; height: 84px; border-radius: 50%;
    display: none; align-items: center; justify-content: center;
    border: 2px solid var(--porcelain); background: color-mix(in srgb, var(--cabinet) 55%, transparent);
    color: var(--porcelain); font-size: 1.6rem; line-height: 1; padding-left: 5px;
    pointer-events: none;
  }
  .reel-video.is-paused .reel-video__resume { display: flex; }
  @keyframes reel-unmute-pulse {
    0%, 100% { box-shadow: 0 10px 30px -8px rgba(0, 0, 0, 0.6), 0 0 0 0 color-mix(in srgb, var(--porcelain) 45%, transparent); }
    50% { box-shadow: 0 10px 30px -8px rgba(0, 0, 0, 0.6), 0 0 0 10px color-mix(in srgb, var(--porcelain) 0%, transparent); }
  }
  @media (prefers-reduced-motion: reduce) { .reel-video__unmute { animation: none; } }
</style>
