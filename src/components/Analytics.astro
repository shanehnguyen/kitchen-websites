---
/* Analytics — Meta Pixel + Microsoft Clarity + optional GA4. All public client
   ids, so they live in site.config (committed), not env vars.

   PERF: the third-party scripts are DEFERRED — they load after the page has
   painted and is interactive (requestIdleCallback, first interaction, or a short
   timeout, whichever comes first). That keeps the header/first render from
   competing with analytics on slow mobile. Preconnects below warm the DNS/TLS so
   the deferred scripts still handshake fast. Meta conversion events fire through
   src/utils/track.js; window.kwTrack carries funnel telemetry to GA4. */
import { site } from '../data/site.config';
const { metaPixelId, ga4Id, clarityId } = site.analytics;
---
{metaPixelId && <link rel="preconnect" href="https://connect.facebook.net" crossorigin />}
{clarityId && <link rel="preconnect" href="https://www.clarity.ms" crossorigin />}

<script is:inline define:vars={{ metaPixelId, ga4Id, clarityId }}>
  (function () {
    var booted = false;
    function boot() {
      if (booted) return; booted = true;

      if (metaPixelId) {
        !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
        n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
        n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
        t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
        document,'script','https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', metaPixelId); fbq('track', 'PageView');
      }

      if (ga4Id) {
        var g = document.createElement('script'); g.async = true;
        g.src = 'https://www.googletagmanager.com/gtag/js?id=' + ga4Id;
        document.head.appendChild(g);
        window.dataLayer = window.dataLayer || [];
        window.gtag = function () { dataLayer.push(arguments); };
        gtag('js', new Date()); gtag('config', ga4Id);
      }

      if (clarityId) {
        (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", clarityId);
      }
    }
    // Load once the main thread is free — or the moment the user interacts,
    // so recordings/events never miss an early action.
    if ('requestIdleCallback' in window) requestIdleCallback(boot, { timeout: 3500 });
    else setTimeout(boot, 1500);
    ['pointerdown', 'keydown', 'scroll', 'touchstart'].forEach(function (ev) {
      addEventListener(ev, boot, { once: true, passive: true });
    });
  })();
</script>

<script is:inline>
  // Internal funnel telemetry → GA4. Meta events go through src/utils/track.js
  // so the Pixel receives just the named conversion events. (Loads immediately —
  // it's tiny and must exist before any CTA click.)
  window.kwTrack = function (name, params) {
    try { if (window.gtag) window.gtag('event', name, params || {}); } catch (e) {}
  };
  // Preserve UTM params across same-origin nav to /book and /scorecard.
  (function () {
    var qs = window.location.search;
    if (!qs || qs.indexOf('utm_') === -1) return;
    document.addEventListener('click', function (e) {
      var a = e.target.closest && e.target.closest('a[href^="/"]');
      if (!a) return;
      var href = a.getAttribute('href');
      if (/\/(book|scorecard)/.test(href) && href.indexOf('utm_') === -1) {
        a.setAttribute('href', href + (href.indexOf('?') > -1 ? '&' : '?') + qs.slice(1));
      }
    });
  })();
</script>
