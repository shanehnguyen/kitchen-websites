---
/* Analytics — Meta Pixel base (fires PageView on every page) + GA4 optional.
   Pixel ID comes from the PUBLIC_META_PIXEL_ID env var (not hardcoded). Meta
   conversion events are fired through src/utils/track.js; window.kwTrack carries
   the internal funnel telemetry to GA4 only, so Meta stays to the named events. */
import { site } from '../data/site.config';
const metaPixelId = import.meta.env.PUBLIC_META_PIXEL_ID;
const { ga4Id } = site.analytics;
---
{metaPixelId && (
  <script is:inline define:vars={{ metaPixelId }}>
    !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
    n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
    document,'script','https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', metaPixelId); fbq('track', 'PageView');
  </script>
)}
{ga4Id && (
  <>
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
    <script is:inline define:vars={{ ga4Id }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date()); gtag('config', ga4Id);
    </script>
  </>
)}
<script is:inline>
  // Internal funnel telemetry → GA4 only. Meta events go through
  // src/utils/track.js so the Pixel receives just the named conversion events.
  window.kwTrack = function (name, params) {
    try { if (window.gtag) window.gtag('event', name, params || {}); } catch (e) {}
  };
  // Preserve UTM params across same-origin nav to /book and /scorecard.
  (function () {
    var qs = window.location.search;
    if (!qs || qs.indexOf('utm_') === -1) return;
    document.addEventListener('click', function (e) {
      var a = e.target.closest && e.target.closest('a[href^="/"]');
      if (!a) return;
      var href = a.getAttribute('href');
      if (/\/(book|scorecard)/.test(href) && href.indexOf('utm_') === -1) {
        a.setAttribute('href', href + (href.indexOf('?') > -1 ? '&' : '?') + qs.slice(1));
      }
    });
  })();
</script>
