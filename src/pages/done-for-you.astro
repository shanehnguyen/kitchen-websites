---
/* /done-for-you — the whole plan. Get found (Google + AI + reviews) and get
   picked (the conversion-built site), built and run for you. Plain-spoken,
   owner-and-money voice. One price, made obvious. One CTA: the call.
   Order: hero (VSL) → what you get + price → guarantee → proof → FAQ → final CTA. */
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButton from '../components/CTAButton.astro';
import FeaturedVideo from '../components/FeaturedVideo.astro';
import StickyMobileCTA from '../components/StickyMobileCTA.astro';
import ClientShowcase from '../components/ClientShowcase.astro';
import FAQ from '../components/FAQ.astro';
import { dfyFaqs } from '../data/faqs';
import { site } from '../data/site.config';

const minutes = site.callLengthMinutes;
// CTAs auto-tag themselves with their `event` (Dfy:HeroToBook, …) via CTAButton,
// so /pulse shows exactly which button sent them. Just point them at /book.
const bookHref = '/book';
const ctaDerisk = 'Free. Kitchen and bath only. Keep the plan either way.';

// "Ninety days from today" — computed at build so the deadline in the final CTA
// stays real on every deploy instead of hardcoding a date that goes stale.
const ninety = new Date(Date.now() + 90 * 24 * 60 * 60 * 1000);
const ordinal = (n: number) => {
  const s = ['th', 'st', 'nd', 'rd'];
  const v = n % 100;
  return `${n}${s[(v - 20) % 10] || s[v] || s[0]}`;
};
const ninetyLabel = `${ninety.toLocaleDateString('en-US', { month: 'long' })} ${ordinal(ninety.getDate())}`;
---
<BaseLayout
  title="Done For You: Get Found & Get Picked | Kitchen Websites"
  description="One package that makes the homeowners already searching find you, trust you, and reach out. 15+ homeowner inquiries in 90 days without a single ad, or I work free until you get there. $750 a month, month to month, you own all of it."
>
  <!-- 1 — HERO -->
  <section class="section seo2-hero">
    <div class="container container--narrow">
      <p class="eyebrow">Done for you · Kitchen &amp; bath only</p>
      <h1 class="seo2-hero__h1">15+ homeowner inquiries in 90 days, without a single ad</h1>
      <p class="seo2-hero__guarantee">or I work free until you get there.</p>
      <p class="lede seo2-hero__sub">The only thing your business needs to start winning homeowners’ trust and landing more jobs online.</p>
    </div>
    <div class="container seo2-hero__video">
      <FeaturedVideo src="/video/done-for-you-video.mp4" poster="/video/done-for-you-video-poster.jpg" autoplay />
    </div>
    <div class="container container--narrow">
      <div class="seo2-hero__cta">
        <CTAButton href={bookHref} label="Get me more inquiries" derisk={`Free ${minutes}-minute call. Kitchen & bath only.`} event="Dfy:HeroToBook" size="lg" />
      </div>
    </div>
  </section>

  <!-- 2 — WHAT YOU GET · WHY IT WORKS -->
  <section class="section seo2-body">
    <div class="container container--prose seo2-prose">
      <p class="seo2-salutation">To the business owner sick and tired of waiting for homeowners to walk through your door…</p>
      <h2 class="seo2-h">Here’s exactly how you’ll get found and chosen online.</h2>
      <p>One package, built and run for you every month.</p>
      <ul class="seo2-gets">
        <li><strong>A website built to convert.</strong> Your kitchens, your reviews, your services, on a site made to turn a homeowner who is just looking into one who calls. You see it before you pay a dollar.</li>
        <li><strong>Your Google profile, rebuilt and run.</strong> The right categories, every service filled in, fresh photos and posts each month, so you climb the map for people searching near you.</li>
        <li><strong>Local SEO that moves you up.</strong> Your site and profile built around what homeowners actually search, so you rise where they’re looking.</li>
        <li><strong>A steady stream of reviews.</strong> Every kitchen you finish becomes another five-star review, the first thing they read before they call.</li>
        <li><strong>Set up for AI search.</strong> When they ask ChatGPT or Google’s AI who to call nearby, you’re one of the names it gives them.</li>
      </ul>

      <h2 class="seo2-h" data-cta-reveal>Why this has worked for kitchen and bath businesses like yours.</h2>
    </div>
    <div class="seo2-proof__showcase"><ClientShowcase /></div>
    <div class="container container--prose seo2-prose">
      <p>Homeowners near you are searching right now, ready to spend twenty or thirty thousand dollars this week. To win them, two things have to go right. They have to find you, then your website has to turn them into a call. I handle both.</p>
      <p>I get you showing up where they look, then build you a site that shows off your best work and answers their worries, so they stop comparing and call you.</p>
      <p class="seo2-beat"><span class="hl">She lands just looking. She leaves ready to call.</span></p>
    </div>
  </section>

  <!-- 3 — THE OFFER: price + guarantee -->
  <section class="section seo2-body">
    <div class="container container--prose seo2-prose">
      <p class="seo2-price__lead">Bought piece by piece, here’s what each one really costs:</p>
      <div class="seo2-compare">
        <table class="cmp">
          <colgroup>
            <col class="cmp__col-piece" />
            <col class="cmp__col-mkt" />
            <col class="cmp__col-me" />
          </colgroup>
          <thead>
            <tr>
              <th scope="col">The piece</th>
              <th scope="col" class="cmp__mkt">Hired out</th>
              <th scope="col" class="cmp__me">With me</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>Website built to convert</td><td class="cmp__mkt">$5,000 build</td><td class="cmp__me">Included</td></tr>
            <tr><td>Website hosting &amp; upkeep</td><td class="cmp__mkt">$150/mo</td><td class="cmp__me">Included</td></tr>
            <tr><td>Local SEO, every month</td><td class="cmp__mkt">$1,500/mo</td><td class="cmp__me">Included</td></tr>
            <tr><td>Google profile, run for you</td><td class="cmp__mkt">$300/mo</td><td class="cmp__me">Included</td></tr>
            <tr><td>Reviews &amp; reputation</td><td class="cmp__mkt">$275/mo</td><td class="cmp__me">Included</td></tr>
            <tr><td>AI search optimization</td><td class="cmp__mkt">$1,000/mo</td><td class="cmp__me">Included</td></tr>
          </tbody>
          <tfoot>
            <tr>
              <td>What you’d pay</td>
              <td class="cmp__mkt">$3,225/mo<span class="cmp__sub">plus $5,000 build</span></td>
              <td class="cmp__me">$750/mo</td>
            </tr>
          </tfoot>
        </table>
      </div>
      <p class="seo2-price">$750 a month. Month to month. You own all of it.</p>
      <p class="seo2-beat"><span class="hl">If you don’t get 15+ homeowner inquiries within ninety days, you stop paying, and I keep working for free until you get there.</span></p>
      <div class="seo2-cta"><CTAButton href={bookHref} label="Get me the whole plan" event="Dfy:PlanToBook" size="lg" /></div>
    </div>
  </section>

  <!-- 4 — THE PROCESS -->
  <section class="section seo2-steps">
    <div class="container container--narrow">
      <h2 class="seo2-steps__h">The simple steps to getting more inquiries.</h2>
      <ol class="seo2-steps__list">
        <li class="seo2-step">
          <span class="seo2-step__n">1</span>
          <div class="seo2-step__body">
            <h3 class="seo2-step__t">Click the button and book your call.</h3>
            <p>A few quick questions to grab your spot. Takes about a minute.</p>
          </div>
        </li>
        <li class="seo2-step">
          <span class="seo2-step__n">2</span>
          <div class="seo2-step__body">
            <h3 class="seo2-step__t">Show up to the call.</h3>
            <p>We build your plan together and I show you exactly how to become the one homeowners call. You keep the plan either way.</p>
          </div>
        </li>
        <li class="seo2-step">
          <span class="seo2-step__n">3</span>
          <div class="seo2-step__body">
            <h3 class="seo2-step__t">We get to work.</h3>
            <p>I build and run your website, your Google, your reviews, and your AI search, and within ninety days you’ve got 15+ homeowner inquiries, or I work free until you get there.</p>
          </div>
        </li>
      </ol>
      <div class="seo2-steps__cta">
        <CTAButton href={bookHref} label="Get me more inquiries" derisk={ctaDerisk} event="Dfy:StepsToBook" size="lg" />
      </div>
    </div>
  </section>

  <!-- 5 — FAQ (light) -->
  <section class="section section--sm seo2-faq">
    <div class="container container--narrow">
      <h2 class="seo2-faq__h">The answers to your burning questions.</h2>
      <div class="seo2-faq__list"><FAQ items={dfyFaqs} /></div>
      <div class="seo2-faq__cta">
        <CTAButton href={bookHref} label="Book my free call" derisk={ctaDerisk} event="Dfy:FaqToBook" size="lg" />
      </div>
    </div>
  </section>

  <!-- 6 — FINAL CTA (dark footer) -->
  <section class="section section--dark seo2-session">
    <div class="container container--narrow seo2-session__inner">
      <h2 class="seo2-session__h">Ninety days from today is {ninetyLabel}.</h2>
      <p>Between now and then, homeowners near you will search, look at three or four names, and call one of them. Your work is already good enough to win those jobs. What decides it is the few minutes she spends looking at you first, and ninety days is how long that takes to fix.</p>
      <p>Tap the button, answer four questions, pick a time. The person who reads your answers and shows up to that call is me.</p>
      <p class="seo2-session__phone">Prefer to skip the form? Call or text <a href={`tel:${site.phone.replace(/[^0-9]/g, '')}`}>{site.phone}</a>.</p>
      <div class="seo2-session__cta">
        <CTAButton href={bookHref} label={`Book my ${minutes} minutes`} derisk="Free. Kitchen and bath only. You keep the plan either way." event="Dfy:SessionToBook" size="lg" />
      </div>
      <p class="seo2-sig">— Shane Nguyen, Kitchen Websites</p>
    </div>
  </section>

  <StickyMobileCTA href={bookHref} label="Get me more inquiries" event="Dfy:StickyToBook" />
</BaseLayout>

<script>
  // Mobile: the header CTA stays hidden over the hero/video and reveals once the
  // visitor scrolls down to the "why this works" heading. (Desktop shows it
  // normally — the cloak CSS is mobile-only.)
  const nav = document.querySelector('[data-nav]');
  const trigger = document.querySelector('[data-cta-reveal]');
  if (nav && trigger && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries) => {
      if (entries.some((e) => e.isIntersecting)) {
        nav.classList.add('nav--cta-on');
        io.disconnect();
      }
    });
    io.observe(trigger);
  } else if (nav) {
    nav.classList.add('nav--cta-on'); // no IntersectionObserver: just show it
  }
</script>

<style>
  /* highlighter device — sits behind the spine lines */
  .hl { background: color-mix(in srgb, var(--accent) 30%, transparent); box-decoration-break: clone; -webkit-box-decoration-break: clone; padding: 0.08em 0.18em; border-radius: 2px; }

  /* hero */
  .seo2-hero { padding-top: var(--space-12); text-align: center; }
  .seo2-hero__h1 { margin: var(--space-4) auto 0; max-width: 24ch; }
  /* the guarantee tail, sitting unbolded under the headline */
  .seo2-hero__guarantee { margin: var(--space-3) auto 0; max-width: 30ch; font-family: var(--font-display); font-weight: var(--fw-body); font-size: var(--fs-h4); line-height: 1.25; color: var(--ink-70); }
  .seo2-hero__sub { margin: var(--space-5) auto 0; max-width: 50ch; }
  .seo2-hero__video { margin-top: var(--space-6); }
  .seo2-hero__cta { margin-top: var(--space-5); display: flex; justify-content: center; }
  .seo2-hero__cta :global(.cta-block) { align-items: center; }

  /* letter body */
  .seo2-date { font-size: var(--fs-caption); color: var(--ink-50); text-transform: uppercase; letter-spacing: var(--tracking-caps); padding-bottom: var(--space-4); border-bottom: var(--rule-width) solid var(--rule); }
  .seo2-h { margin-top: var(--space-10); font-size: var(--fs-h3); }
  /* salutation lead-in (regular text), then the bold heading sits close under it */
  .seo2-prose p.seo2-salutation { margin-top: 0; }
  .seo2-salutation + .seo2-h { margin-top: var(--space-4); }
  .seo2-prose p { margin-top: var(--space-4); font-family: var(--font-serif); font-size: var(--fs-bodyL); line-height: 1.7; color: var(--ink); }
  .seo2-prose h2 + p { margin-top: var(--space-5); }
  .seo2-beat { font-family: var(--font-serif); }
  .seo2-cta { margin-top: var(--space-6); }

  /* "exactly what you get" list */
  .seo2-gets { list-style: none; padding: 0; margin: var(--space-6) 0; display: grid; gap: var(--space-4); }
  .seo2-gets li { position: relative; padding-left: var(--space-6); font-family: var(--font-serif); font-size: var(--fs-bodyL); line-height: 1.6; color: var(--ink-70); }
  .seo2-gets li::before { content: ""; position: absolute; left: 0; top: 0.6em; width: 14px; height: 2px; background: var(--accent); }
  .seo2-gets strong { color: var(--ink); font-weight: var(--fw-body-bold); }

  /* price — the obvious part */
  .seo2-price__lead { margin-top: var(--space-6); }

  /* à-la-carte vs. me comparison table — the "With me" column is the hero, the
     hired-out prices are struck through so the deal reads at a glance. */
  .seo2-compare { margin-top: var(--space-5); overflow-x: auto; }
  .cmp { width: 100%; border-collapse: collapse; font-family: var(--font-body); table-layout: fixed; }
  .cmp th, .cmp td { padding: var(--space-3) var(--space-3); text-align: left; border-bottom: var(--rule-width) solid var(--rule); vertical-align: middle; }
  .cmp col.cmp__col-piece { width: 46%; }
  .cmp col.cmp__col-mkt { width: 27%; }
  .cmp col.cmp__col-me { width: 27%; }
  .cmp thead th { font-size: var(--fs-caption); text-transform: uppercase; letter-spacing: var(--tracking-caps); font-weight: var(--fw-body-semi); color: var(--ink-50); }
  .cmp thead .cmp__me { color: var(--accent-deep); }
  .cmp tbody td:first-child { font-family: var(--font-serif); font-size: var(--fs-body); color: var(--ink); line-height: 1.25; }
  .cmp__mkt { text-align: right; color: var(--ink-50); }
  /* strike the hired-out prices — what they DON'T pay */
  .cmp tbody .cmp__mkt, .cmp tfoot .cmp__mkt { text-decoration: line-through; text-decoration-color: color-mix(in srgb, var(--alarm) 70%, transparent); text-decoration-thickness: 2px; }
  .cmp__me { text-align: right; color: var(--accent-deep); font-weight: var(--fw-body-bold); background: color-mix(in srgb, var(--accent) 12%, transparent); }
  .cmp tbody .cmp__me::before { content: "✓ "; }
  .cmp tfoot td { border-bottom: 0; border-top: var(--rule-thick) solid var(--ink); font-size: var(--fs-bodyL); font-weight: var(--fw-body-bold); color: var(--ink); }
  .cmp tfoot td:first-child { text-transform: uppercase; letter-spacing: 0.02em; }
  .cmp tfoot .cmp__me { color: var(--accent-deep); font-size: var(--fs-h4); }
  .cmp__sub { display: block; font-family: var(--font-body); font-size: var(--fs-caption); font-weight: var(--fw-body); color: var(--ink-50); text-decoration: none; }
  .seo2-price { margin-top: var(--space-4); font-family: var(--font-display); font-weight: var(--fw-display); text-transform: uppercase; letter-spacing: var(--tracking-display); font-size: var(--fs-h2); line-height: 1.1; color: var(--ink); }
  /* mobile: shrink so all three columns fit without a horizontal scroll */
  @media (max-width: 40em) {
    .cmp th, .cmp td { padding: var(--space-2) var(--space-1); }
    .cmp thead th { font-size: 0.6rem; letter-spacing: 0.02em; }
    .cmp tbody td:first-child { font-size: var(--fs-caption); }
    .cmp__mkt, .cmp__me { font-size: var(--fs-caption); }
    .cmp tfoot td { font-size: var(--fs-body-sm); }
    .cmp tfoot .cmp__me { font-size: var(--fs-bodyL); }
    .cmp__sub { font-size: 0.58rem; }
  }

  /* proof — rotating client showcase, sits under the "why it works" beat */
  .seo2-proof__showcase { margin-top: var(--space-8); }

  /* the process — 3 numbered steps to start */
  .seo2-steps__h { text-align: center; font-size: var(--fs-h3); }
  .seo2-steps__list { list-style: none; padding: 0; margin: var(--space-8) auto 0; display: grid; gap: var(--space-6); max-width: 42rem; }
  .seo2-step { display: flex; gap: var(--space-4); align-items: flex-start; }
  .seo2-step__n { flex: 0 0 auto; width: 44px; height: 44px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-weight: var(--fw-display); font-size: var(--fs-h4); line-height: 1; color: var(--accent-deep); background: color-mix(in srgb, var(--accent) 14%, transparent); border: var(--rule-thick) solid var(--accent); }
  .seo2-step__t { font-size: var(--fs-h4); }
  .seo2-step__body p { margin-top: var(--space-2); font-family: var(--font-serif); font-size: var(--fs-bodyL); line-height: 1.6; color: var(--ink-70); }
  .seo2-steps__cta { margin-top: var(--space-10); display: flex; justify-content: center; }
  .seo2-steps__cta :global(.cta-block) { align-items: center; }

  /* faq (light section) */
  .seo2-faq__h { font-size: var(--fs-h3); max-width: none; }
  .seo2-faq__list { margin-top: var(--space-8); }
  .seo2-faq__cta { margin-top: var(--space-10); display: flex; justify-content: center; }
  .seo2-faq__cta :global(.cta-block) { align-items: center; }

  /* final cta (dark footer) — lift text to the dark palette */
  .seo2-session__inner { text-align: center; }
  .seo2-session__h { font-family: var(--font-display); color: var(--dark-ink); }
  .seo2-session__inner p { margin-top: var(--space-4); font-family: var(--font-serif); font-size: var(--fs-bodyL); line-height: 1.65; color: var(--dark-soft); max-width: 56ch; margin-inline: auto; }
  .seo2-em { color: var(--accent); font-weight: var(--fw-body-bold); }
  .seo2-session__phone { font-size: var(--fs-body) !important; color: var(--dark-soft); }
  .seo2-session__phone a { color: var(--dark-ink); font-weight: var(--fw-body-bold); text-decoration: underline; text-underline-offset: 3px; }
  .seo2-session__phone a:hover { color: var(--accent); }
  .seo2-session__cta { margin-top: var(--space-8); display: flex; justify-content: center; }
  .seo2-session__cta :global(.cta-block) { align-items: center; }
  .seo2-sig { margin-top: var(--space-8); font-family: var(--font-display) !important; font-size: var(--fs-h4) !important; color: var(--dark-ink) !important; }
</style>
