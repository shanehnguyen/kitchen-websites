---
/* /book — the 30-minute strategy session as a PROGRESSIVE, stacked form. The
   first question shows; answering it reveals the next right below it, and every
   answered question stays visible, so by the end the whole thing reads back as
   one page. It's a SINGLE <form>; values live in the DOM and persist to
   sessionStorage so nothing is lost (and autofill just works — nothing is hidden
   in a way that breaks it). On submit the lead fires to Web3Forms and the
   Calendly calendar reveals beneath the answers; a booked time → confirmation. */
import BareLayout from '../layouts/BareLayout.astro';
import { site } from '../data/site.config';
const minutes = site.callLengthMinutes;
// Small static proof row — real client sites, all shown at once, no animation.
const portfolio = [
  { img: '/assets/images/portfolio/absolute-kitchen-distributors-website-design.png', brand: 'Absolute Kitchen Distributors', alt: 'Absolute Kitchen Distributors website' },
  { img: '/assets/images/portfolio/austin-home-creations-website-design.png', brand: 'Austin Home Creations', alt: 'Austin Home Creations website' },
  { img: '/assets/images/portfolio/kitch-cabinetry-website-design.png', brand: 'Kitch Cabinetry', alt: 'Kitch Cabinetry website' },
  { img: '/assets/images/portfolio/pk-cabinet-website-design.png', brand: 'PK Cabinet', alt: 'PK Cabinet website' },
  { img: '/assets/images/portfolio/texas-remodelers-build-website-design.png', brand: 'Texas Remodelers Build', alt: 'Texas Remodelers Build website' },
];
---
<BareLayout
  title={`Book your ${minutes}-minute strategy session`}
  description="Thirty minutes with me and you walk off with a plan to turn the homeowners checking you out into booked jobs. A few quick questions, then pick a time."
  noindex={true}
>
  <div data-book-flow>
    <section class="section bk-funnel">
      <div class="container container--narrow">

        <header class="bk-intro">
          <p class="eyebrow">For kitchen &amp; bath businesses</p>
          <h1 class="bk-intro__h1">Your free <span class="bk-nowrap">{minutes}-minute</span> strategy session</h1>
          <p class="bk-intro__sub" data-sub>In {minutes} minutes we break down the three things that decide who homeowners call: your website, your Google ranking, and AI search. Then I study your biggest competitors and hand you the exact gameplan to beat them.</p>
        </header>

        <!-- proof: real client sites, small, all visible, no animation -->
        <div class="bk-proof">
          <p class="bk-proof__h">Join the owners already winning their market.</p>
          <div class="bk-proof__grid">
            {portfolio.map((p) => (
              <figure class="bk-shot">
                <img src={p.img} alt={p.alt} loading="lazy" decoding="async" />
                <figcaption class="bk-shot__brand">{p.brand}</figcaption>
              </figure>
            ))}
          </div>
        </div>

        <p class="bk-reassure" data-reassure>You leave with the plan — yours to keep, even if we never work together.</p>

        <form class="bk-form" data-book-form novalidate>

          <!-- Q1 — WHICH SOUNDS LIKE YOU -->
          <fieldset class="bk-step" data-step>
            <h2 class="bk-q">Which sounds like you?</h2>
            <div class="bk-field" data-field="businessType">
              <div class="bk-cards bk-cards--row bk-cards--wide" data-name="businessType" data-radio>
                <button type="button" class="bk-card" data-value="Showroom or dealer">Showroom or dealer</button>
                <button type="button" class="bk-card" data-value="Remodeler">Remodeler</button>
                <button type="button" class="bk-card" data-value="Countertop or stone shop">Countertop or stone shop</button>
                <button type="button" class="bk-card" data-value="A bit of everything">A bit of everything</button>
              </div>
            </div>
            <div class="bk-nav"><button type="button" class="btn btn--primary" data-next>Continue <span aria-hidden="true">→</span></button></div>
          </fieldset>

          <!-- Q2 — WHERE JOBS COME FROM + HOW MANY -->
          <fieldset class="bk-step" data-step hidden>
            <p class="bk-count">2/3</p>
            <h2 class="bk-q">A little about your jobs.</h2>
            <div class="bk-field" data-field="customers">
              <p class="bk-sub">Where do your jobs mainly come from?</p>
              <div class="bk-cards bk-cards--row3 bk-cards--wide" data-name="customers" data-radio>
                <button type="button" class="bk-card" data-value="Mostly homeowners">Mostly homeowners</button>
                <button type="button" class="bk-card" data-value="Mostly builder & contractor">Mostly builder &amp; contractor</button>
                <button type="button" class="bk-card" data-value="A mix">A mix</button>
              </div>
            </div>
            <div class="bk-field" data-field="jobs">
              <p class="bk-sub bk-sub--gap">Roughly how many kitchens or baths a month?</p>
              <div class="bk-cards bk-cards--row bk-cards--wide" data-name="jobs" data-radio>
                <button type="button" class="bk-card" data-value="1–2">1–2</button>
                <button type="button" class="bk-card" data-value="3–5">3–5</button>
                <button type="button" class="bk-card" data-value="6–10">6–10</button>
                <button type="button" class="bk-card" data-value="10+">10+</button>
              </div>
            </div>
            <div class="bk-nav"><button type="button" class="btn btn--primary" data-next>Continue <span aria-hidden="true">→</span></button></div>
          </fieldset>

          <!-- Q3 — BUSINESS NAME + WEBSITE → submit -->
          <fieldset class="bk-step" data-step hidden>
            <p class="bk-count">3/3</p>
            <h2 class="bk-q">Last thing — your business.</h2>
            <div class="bk-fields bk-fields--2">
              <div class="bk-field" data-field="businessName">
                <label class="bk-label" for="bk-businessName">Business name</label>
                <input class="bk-input" id="bk-businessName" name="businessName" type="text" autocomplete="organization" placeholder="Your business name" required />
              </div>
              <div class="bk-field" data-field="website">
                <label class="bk-label" for="bk-website">Website <span class="bk-opt">(optional)</span></label>
                <input class="bk-input" id="bk-website" name="website" type="text" autocomplete="url" placeholder="yoursite.com" />
              </div>
            </div>
            <div class="bk-nav"><button type="button" class="btn btn--primary btn--lg" data-submit>Book my session <span aria-hidden="true">→</span></button></div>
            <p class="bk-form__status mono" data-book-status hidden></p>
          </fieldset>

          <!-- honeypot. A CHECKBOX, not a text input: browser autofill and
               password managers fill TEXT fields (name/email/company/etc.) and
               were dumping a value into the old text trap, silently blocking real
               bookings. Nothing ever auto-ticks a checkbox, so only a bot that
               checks every input gets caught here. -->
          <div class="honeypot" aria-hidden="true">
            <input id="hp-confirm" name="hp_confirm" type="checkbox" tabindex="-1" autocomplete="off" aria-hidden="true" />
          </div>
        </form>

        <!-- CALENDAR — revealed beneath the answers once the form is submitted -->
        <div class="bk-step bk-step--cal" data-step="cal" hidden>
          <h2 class="bk-cal__h">Got your details. Pick a time that works.</h2>
          <p class="bk-cal__note">You leave with the written plan whether we ever work together or not.</p>
          <div class="bk-cal__widget" data-calendly></div>
          <a class="bk-cal__direct" href={site.bookingUrl} target="_blank" rel="noopener">Calendar not loading? Open it in a new tab →</a>
        </div>

      </div>
    </section>
  </div>

  <!-- CONFIRMATION (after Calendly schedules) -->
  <section class="section bk-done" data-book-done hidden>
    <div class="container container--narrow">
      <p class="eyebrow">You’re on the books</p>
      <h2 class="bk-done__h">You’re on the books.</h2>
      <p class="bk-done__p">Check your email for the time and the call link. Before we talk, I’ll dig into your business’s setup so we don’t waste a minute playing catch-up.</p>
      <p class="bk-done__sig">See you then.<br />— Shane</p>
    </div>
  </section>
</BareLayout>

<script>
  import { site } from '../data/site.config';
  import { pulseId, pulseSource, pulseSend } from '../utils/pulse.js';
  import { track } from '../utils/track.js';
  const bookingUrl = site.bookingUrl;

  const form = document.querySelector<HTMLFormElement>('[data-book-form]');
  const flow = document.querySelector<HTMLElement>('[data-book-flow]');
  const done = document.querySelector<HTMLElement>('[data-book-done]');
  const calStep = document.querySelector<HTMLElement>('[data-step="cal"]');

  // Tailor the intro to where they came from (?from=). Someone arriving from the
  // done-for-you page is already sold, so warm the greeting and drop the re-pitch
  // — the bullets still show what the session delivers.
  {
    const from = new URLSearchParams(location.search).get('from');
    if (from && from.toLowerCase().startsWith('dfy')) {
      const reassureEl = document.querySelector<HTMLElement>('[data-reassure]');
      if (reassureEl) reassureEl.textContent = 'Yours to keep, even if we never work together.';
    }
  }

  // text/textarea answers live in the DOM; radios are tracked here too
  const answers: Record<string, string> = {};

  if (form) {
    const steps = Array.from(form.querySelectorAll<HTMLElement>('[data-step]'));
    let current = 0;

    const emailOk = (v: string) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);

    // ---- visible validation (shows messages + shakes) ----
    const fieldWrap = (name: string) => form.querySelector<HTMLElement>(`[data-field="${name}"]`);
    function showErr(name: string, msg: string) {
      const wrap = fieldWrap(name);
      if (!wrap) return;
      wrap.classList.add('bk-field--err');
      let m = wrap.querySelector<HTMLElement>('.bk-err');
      if (!m) { m = document.createElement('p'); m.className = 'bk-err'; m.setAttribute('role', 'alert'); wrap.appendChild(m); }
      m.textContent = msg;
    }
    function clearErr(name: string) {
      const wrap = fieldWrap(name);
      if (!wrap) return;
      wrap.classList.remove('bk-field--err');
      wrap.querySelector('.bk-err')?.remove();
    }
    const shake = (step: HTMLElement) => { step.classList.remove('bk-step--err'); void step.offsetWidth; step.classList.add('bk-step--err'); };

    const validStep = (step: HTMLElement) => {
      let ok = true;
      step.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input[name], textarea[name]').forEach((f) => {
        if (f.name === 'hp_confirm' || !f.required) return;
        const name = (f.closest('[data-field]') as HTMLElement)?.dataset.field || f.name;
        if (!f.value.trim()) { showErr(name, 'Please fill this in to continue.'); ok = false; }
        else if ((f as HTMLInputElement).type === 'email' && !emailOk(f.value)) { showErr(name, 'That email doesn’t look right.'); ok = false; }
        else clearErr(name);
      });
      step.querySelectorAll<HTMLElement>('[data-radio]').forEach((g) => {
        const name = g.dataset.name!;
        if (!g.querySelector('.is-on')) { showErr(name, 'Pick an option to continue.'); ok = false; }
        else clearErr(name);
      });
      if (!ok) shake(step);
      return ok;
    };

    // ---- silent validity (used to resume saved progress without flashing errors) ----
    const stepValid = (step: HTMLElement) => {
      let ok = true;
      step.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input[name], textarea[name]').forEach((f) => {
        if (f.name === 'hp_confirm' || !f.required) return;
        if (!f.value.trim()) ok = false;
        else if ((f as HTMLInputElement).type === 'email' && !emailOk(f.value)) ok = false;
      });
      step.querySelectorAll<HTMLElement>('[data-radio]').forEach((g) => { if (!g.querySelector('.is-on')) ok = false; });
      return ok;
    };

    // ---- persistence: never lose answers between reveals or on reload ----
    const STORE = 'kw_book_v1';
    const collectAll = () => {
      form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input[name], textarea[name]').forEach((f) => {
        if (f.name === 'hp_confirm') return;
        if ((f as HTMLInputElement).type === 'radio' || (f as HTMLInputElement).type === 'checkbox') return;
        answers[f.name] = f.value.trim();
      });
    };
    const persist = () => { try { collectAll(); sessionStorage.setItem(STORE, JSON.stringify(answers)); } catch { /* ignore */ } };
    const restore = () => {
      let saved: Record<string, string> = {};
      try { saved = JSON.parse(sessionStorage.getItem(STORE) || '{}'); } catch { return; }
      Object.assign(answers, saved);
      Object.entries(saved).forEach(([k, v]) => {
        const el = form.querySelector<HTMLInputElement | HTMLTextAreaElement>(`[name="${k}"]`);
        if (el && typeof v === 'string') el.value = v;
      });
      form.querySelectorAll<HTMLElement>('[data-radio]').forEach((g) => {
        const val = saved[g.dataset.name!];
        if (val) g.querySelectorAll<HTMLElement>('.bk-card').forEach((c) => c.classList.toggle('is-on', c.dataset.value === val));
      });
    };
    // Re-apply each field's value to itself so an AUTOFILLED value is materialised
    // as a real, committed DOM value before we read it for validation/submit. This
    // is the "restart the screen but keep everything" trick — re-rendering the
    // values (what a reload's restore does) is what makes autofill behave.
    const commitFields = () => {
      collectAll();
      Object.entries(answers).forEach(([k, v]) => {
        const el = form.querySelector<HTMLInputElement | HTMLTextAreaElement>(`[name="${k}"]`);
        if (el) el.value = v;
      });
    };

    // ---- booking pulse: report how far each visitor gets, so drop-offs email
    //      Shane and the /pulse dashboard shows the funnel. Stage only moves
    //      forward; the beacon carries whatever they've filled in so far. ----
    const nowMs = () => Date.now();
    const PULSE = { id: pulseId(), stage: 'landed', landedAt: nowMs(), stageTimes: {}, ...pulseSource() };
    const PSTAGES = ['landed', 'type', 'jobs', 'details', 'calendar', 'booked'];
    const prank = (s) => PSTAGES.indexOf(s);
    PULSE.stageTimes.landed = PULSE.landedAt; // stamp the landing as the first stage time
    const pulsePayload = (final) => {
      collectAll();
      return {
        id: PULSE.id, stage: PULSE.stage,
        businessType: answers.businessType || '', businessName: answers.businessName || '',
        website: answers.website || '', customers: answers.customers || '', jobs: answers.jobs || '',
        source: PULSE.source, referrer: PULSE.referrer, query: PULSE.query,
        utmSource: PULSE.utmSource, utmMedium: PULSE.utmMedium, utmCampaign: PULSE.utmCampaign,
        utmContent: PULSE.utmContent, utmTerm: PULSE.utmTerm, gclid: PULSE.gclid, fbclid: PULSE.fbclid,
        stageTimes: PULSE.stageTimes,
        landedAt: PULSE.landedAt, final: !!final,
      };
    };
    // Advance the stage (never backward) and beacon. Repeats at the same stage
    // are dropped unless it's the "leaving" (final) ping. The first time a stage
    // is reached we stamp its timestamp, so /pulse can show the time to each step.
    const setStage = (s, final = false) => {
      const up = prank(s) > prank(PULSE.stage);
      if (up) {
        PULSE.stage = s;
        if (!PULSE.stageTimes[s]) PULSE.stageTimes[s] = nowMs();
      }
      if (up || final) pulseSend(pulsePayload(final), final);
    };
    // Furthest step → stage: Q1 (type) · Q2 (jobs) · Q3 (business) · calendar · booked.
    const stageForCurrent = () =>
      current >= 2 ? 'details' : current >= 1 ? 'jobs'
      : (answers.businessType ? 'type' : 'landed');

    // ---- progressive reveal: keep steps 0..current visible, only the current
    //      step shows its Continue/Submit button ----
    const reveal = (n: number, scroll = false) => {
      current = Math.max(0, Math.min(steps.length - 1, n));
      steps.forEach((s, idx) => {
        if (idx <= current) s.hidden = false;
        s.classList.toggle('is-current', idx === current);
      });
      const step = steps[current];
      if (scroll) {
        step.scrollIntoView({ behavior: 'smooth', block: 'center' });
        const focusable = step.querySelector<HTMLElement>('input:not([type=hidden]), textarea');
        requestAnimationFrame(() => focusable?.focus());
      }
    };

    const advance = () => {
      if (current < steps.length - 1) reveal(current + 1, true);
      setStage(stageForCurrent());
    };

    const showCalendar = () => {
      steps.forEach((s) => s.classList.remove('is-current'));
      if (calStep) {
        calStep.hidden = false;
        initCalendly();
        calStep.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    };

    // Meta "started booking" intent — fires ONCE the moment they answer the first
    // question (business type). Form completion is too rare to optimise against, so
    // BookClicked marks the top of the funnel; Lead still fires on completion below.
    // Anti-spam: guarded within the page load AND persisted per session, so
    // reloading + re-picking (or a bot hammering the option) can't refire it.
    const BOOK_STARTED_KEY = 'kw_book_started_v1';
    let bookStartedFired = false;
    try { if (sessionStorage.getItem(BOOK_STARTED_KEY)) bookStartedFired = true; } catch { /* ignore */ }
    const fireBookStarted = () => {
      if (bookStartedFired) return;
      bookStartedFired = true;
      try { sessionStorage.setItem(BOOK_STARTED_KEY, '1'); } catch { /* ignore */ }
      track('BookClicked');
    };

    // single-choice cards
    form.querySelectorAll<HTMLElement>('[data-radio]').forEach((group) => {
      group.querySelectorAll<HTMLButtonElement>('.bk-card').forEach((card) => {
        card.addEventListener('click', () => {
          group.querySelectorAll('.bk-card').forEach((c) => c.classList.remove('is-on'));
          card.classList.add('is-on');
          answers[group.dataset.name!] = card.dataset.value!;
          clearErr(group.dataset.name!);
          persist();
          setStage(stageForCurrent()); // picking Q1 flips landed → type
          if (group.dataset.name === 'businessType') fireBookStarted(); // first question answered
        });
      });
    });

    // clear error + persist as the user types OR autofills (autofill often fires
    // 'change' rather than 'input', so listen for both)
    form.querySelectorAll<HTMLInputElement>('input[name], textarea[name]').forEach((f) => {
      const onEdit = () => {
        clearErr((f.closest('[data-field]') as HTMLElement)?.dataset.field || f.name);
        persist();
      };
      f.addEventListener('input', onEdit);
      f.addEventListener('change', onEdit);
    });

    // Send the qualified lead to Web3Forms — fires when they COMPLETE the form and
    // reach the calendar. Contact (name/email) is collected by Calendly at the
    // booking step, so the lead carries the qualifying answers + attribution.
    // Fire-and-forget; guarded against double-send within a page load.
    let leadSent = false;
    const sendLead = () => {
      if (leadSent) return;
      leadSent = true;
      collectAll();
      const fd = new FormData();
      fd.append('access_key', site.web3formsBookingKey);
      fd.append('from_name', 'Kitchen Websites');
      fd.append('subject', `📋 Session request — ${answers.businessName || 'new owner'}`);
      fd.append('Business', answers.businessName || '');
      fd.append('Website', answers.website || '');
      fd.append('Type', answers.businessType || '');
      fd.append('Jobs come from', answers.customers || '');
      fd.append('Jobs / month', answers.jobs || '');
      fd.append('Note', 'Name + email are collected in Calendly at booking.');
      const params = new URLSearchParams(window.location.search);
      if (params.get('from')) fd.append('Came from', String(params.get('from')));
      if (window.location.search) fd.append('Query params', window.location.search);
      if (document.referrer) fd.append('Referrer', document.referrer);
      fetch('https://api.web3forms.com/submit', { method: 'POST', body: fd }).catch(() => { /* best-effort */ });
    };

    // Form complete → this IS the lead. Fire the lead notification + Meta Lead
    // here, then reveal the calendar (Calendly collects name/email + the time).
    let leadFired = false;
    const doSubmit = () => {
      const last = steps[steps.length - 1];
      if (!validStep(last)) return;                 // website optional; business name required
      if (form.querySelector<HTMLInputElement>('[name="hp_confirm"]')?.checked) return; // honeypot
      collectAll();
      if (!leadFired) {
        leadFired = true;
        sendLead();                                          // Web3Forms — the qualified lead
        (window as any).kwTrack?.('LeadQualified', { via: 'session-funnel' });
        if ((window as any).fbq) (window as any).fbq('track', 'Lead'); // Meta Lead — on form completion
      }
      setStage('calendar');
      showCalendar();
    };

    // safety net: if the flow is ever interrupted or throws, don't leave the user
    // stuck on a dead button — tell them and restart cleanly from the top.
    const bail = (msg: string) => {
      try { sessionStorage.removeItem(STORE); } catch { /* ignore */ }
      Object.keys(answers).forEach((k) => delete answers[k]);
      try { form.reset(); } catch { /* ignore */ }
      form.querySelectorAll('.bk-field--err').forEach((el) => el.classList.remove('bk-field--err'));
      form.querySelectorAll('.bk-err').forEach((el) => el.remove());
      form.querySelectorAll('.bk-card.is-on').forEach((el) => el.classList.remove('is-on'));
      if (calStep) calStep.hidden = true;
      reveal(0);
      window.alert(msg);
    };
    const INTERRUPT_MSG = 'Something interrupted the form, so we’ve reset it. Mind starting over? It only takes a minute.';

    form.addEventListener('click', (e) => {
      try {
        const t = e.target as HTMLElement;
        if (t.closest('[data-next]')) { commitFields(); if (validStep(steps[current])) advance(); }
        else if (t.closest('[data-submit]')) { commitFields(); doSubmit(); }
      } catch (err) { console.error('[book] form interrupted:', err); bail(INTERRUPT_MSG); }
    });

    form.addEventListener('keydown', (e) => {
      if (e.key !== 'Enter') return;
      if ((e.target as HTMLElement).tagName === 'TEXTAREA') return;
      e.preventDefault(); // Enter must never natively submit / reload the page
      try {
        const step = steps[current];
        commitFields();
        if (step.querySelector('[data-submit]')) doSubmit();
        else if (validStep(step)) advance();
      } catch (err) { console.error('[book] form interrupted:', err); bail(INTERRUPT_MSG); }
    });

    // hard safety net: the form can never natively submit (which would reload + reset it)
    form.addEventListener('submit', (e) => { e.preventDefault(); });

    // Prefill payload for Calendly, read LIVE from what they just entered so the
    // calendar step is confirm-and-pick, not re-type. `name`/`email` are
    // Calendly's built-in fields (always safe). customAnswers a1..aN map to the
    // event type's Invitee Questions *in order* — VERIFY that order in Calendly
    // (event type → Invitee Questions); a mismatch is a one-line fix right here,
    // not a code hunt. Calendly ignores answer keys the event type doesn't have.
    // Prefill Calendly's custom questions with the qualifying answers so they're
    // not re-asked. Calendly collects name + email itself, so we don't prefill
    // those. customAnswers a1..aN map to the event type's Invitee Questions IN
    // ORDER — verify that order in Calendly; a mismatch is a one-line fix here.
    const calendlyPrefill = () => {
      collectAll();
      const customAnswers: Record<string, string> = {};
      if (answers.businessName) customAnswers.a1 = answers.businessName; // Q1 · business name
      if (answers.businessType) customAnswers.a2 = answers.businessType; // Q2 · business type
      if (answers.customers)    customAnswers.a3 = answers.customers;    // Q3 · jobs come from
      if (answers.jobs)         customAnswers.a4 = answers.jobs;         // Q4 · jobs per year
      if (answers.website)      customAnswers.a5 = answers.website;      // Q5 · website
      return { customAnswers };
    };
    // Keep the "open in a new tab" fallback prefilled too (URL query-param form).
    const syncDirectLink = () => {
      const link = document.querySelector<HTMLAnchorElement>('.bk-cal__direct');
      if (!link) return;
      const p = calendlyPrefill();
      const qs = new URLSearchParams();
      Object.entries(p.customAnswers).forEach(([k, v]) => qs.set(k, v));
      const base = bookingUrl.split('?')[0];
      link.href = qs.toString() ? `${base}?${qs.toString()}` : bookingUrl;
    };

    // ---- Calendly inline embed (loaded lazily when the calendar reveals) ----
    function initCalendly() {
      const host = document.querySelector<HTMLElement>('[data-calendly]');
      if (!host || host.dataset.ready) return;
      syncDirectLink(); // fallback link is prefilled the moment the calendar shows
      const w = window as any;
      const go = () => {
        if (!w.Calendly) return;
        host.dataset.ready = '1';
        w.Calendly.initInlineWidget({
          url: bookingUrl,
          parentElement: host,
          prefill: calendlyPrefill(),
        });
      };
      if (w.Calendly) { go(); return; }
      if (!document.querySelector('link[data-calendly-css]')) {
        const link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = 'https://assets.calendly.com/assets/external/widget.css';
        link.setAttribute('data-calendly-css', '');
        document.head.appendChild(link);
      }
      const s = document.createElement('script');
      s.src = 'https://assets.calendly.com/assets/external/widget.js';
      s.async = true;
      s.onload = go;
      document.body.appendChild(s);
    }

    // Calendly messages: keep the embed sized to its content (no inner scroll),
    // and swap to the confirmation once a time is picked.
    window.addEventListener('message', (e) => {
      const data = (e.data as any);
      if (data?.event === 'calendly.page_height' && data.payload?.height) {
        const host = document.querySelector<HTMLElement>('[data-calendly]');
        if (host) host.style.height = data.payload.height;
        return;
      }
      if (data?.event === 'calendly.event_scheduled') {
        // Lead already fired at form completion; this is the actual booking.
        (window as any).kwTrack?.('CallBooked', { via: 'calendly' });
        if ((window as any).fbq) (window as any).fbq('track', 'CallBooked');
        setStage('booked', true);
        try { sessionStorage.removeItem(STORE); } catch { /* ignore */ }
        if (flow) flow.hidden = true;
        if (done) done.hidden = false;
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    });

    // ---- boot ----
    restore();           // refill anything saved from a previous visit
    reveal(0);           // first question is always visible
    // resume: fast-forward past any steps already answered from a prior visit
    while (current < steps.length - 1 && stepValid(steps[current])) reveal(current + 1);

    // booking pulse: first ping (landed, or resumed further), then report as
    // they leave. visibilitychange keeps the dashboard fresh; pagehide is the
    // real exit and is what may trigger the drop-off email.
    PULSE.stage = stageForCurrent();
    pulseSend(pulsePayload(false));
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'hidden') pulseSend(pulsePayload(false));
    });
    window.addEventListener('pagehide', () => pulseSend(pulsePayload(true), true));
  }
</script>

