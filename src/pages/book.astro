---
/* /book — the 30-minute strategy session funnel. One question per screen
   (intro → name → contact → your work → the obstacle), then the Calendly
   calendar. It's a SINGLE <form>: every field's value persists in the DOM even
   while its screen is hidden, so at submit we read ALL answers from the whole
   form at once — nothing can be lost moving between screens. Lead goes to
   Web3Forms client-side (fire-and-forget); then it flips to the inline calendar
   and, once a time is picked, to the confirmation. */
import BareLayout from '../layouts/BareLayout.astro';
import { site } from '../data/site.config';
const minutes = site.callLengthMinutes;
const DOTS = 4; // question screens 1–4
---
<BareLayout
  title={`Book your ${minutes}-minute strategy session`}
  description="Thirty minutes with me and you walk off with a plan to turn the homeowners checking you out into booked jobs. A few quick questions, then pick a time."
  noindex={true}
>
  <div data-book-flow>
    <div class="bk-prog" data-prog-row aria-hidden="true">
      {Array.from({ length: DOTS }).map(() => <span class="bk-dot"></span>)}
    </div>

    <section class="section bk-funnel">
      <div class="container container--narrow">
        <form class="bk-form" data-book-form novalidate>

          <!-- 0 — INTRO -->
          <fieldset class="bk-screen bk-screen--intro" data-screen="0" data-active>
            <p class="eyebrow">For kitchen &amp; bath businesses</p>
            <h1 class="bk-intro__h1">Your free {minutes}-minute game plan</h1>
            <p class="bk-intro__lede">Thirty minutes with me, and you walk off with a plan to get found by the homeowners already looking and chosen over the business down the road. The kind of plan I’d normally only put together for a paying client.</p>
            <p class="bk-intro__sub">It’s for owners who do good work and are done watching it go to businesses that do worse.</p>
            <div class="bk-nav"><button type="button" class="btn btn--primary btn--lg" data-next>Get started <span aria-hidden="true">→</span></button></div>
          </fieldset>

          <!-- 1 — NAME -->
          <fieldset class="bk-screen" data-screen="1" data-field="name" hidden>
            <h2 class="bk-q">What do I call you?</h2>
            <input class="bk-input" name="name" type="text" autocomplete="given-name" placeholder="First name" required />
            <div class="bk-nav"><button type="button" class="btn btn--primary" data-next>Continue <span aria-hidden="true">→</span></button></div>
          </fieldset>

          <!-- 2 — CONTACT -->
          <fieldset class="bk-screen" data-screen="2" hidden>
            <h2 class="bk-q">A few quick details, <span data-first>there</span>.</h2>
            <div class="bk-fields">
              <label class="bk-field" data-field="mobile">
                <span class="bk-label">Best mobile, in case we get cut off?</span>
                <input class="bk-input" name="mobile" type="tel" autocomplete="tel" placeholder="Mobile number" required />
              </label>
              <label class="bk-field" data-field="email">
                <span class="bk-label">Best email for the calendar invite?</span>
                <input class="bk-input" name="email" type="email" autocomplete="email" placeholder="you@email.com" required />
              </label>
              <label class="bk-field" data-field="website">
                <span class="bk-label">What’s your website? No site yet? Just your business name and city.</span>
                <input class="bk-input" name="website" type="text" placeholder="yoursite.com, or business name and city" required />
              </label>
            </div>
            <div class="bk-nav"><button type="button" class="bk-back" data-back>← Back</button><button type="button" class="btn btn--primary" data-next>Continue <span aria-hidden="true">→</span></button></div>
          </fieldset>

          <!-- 3 — YOUR WORK -->
          <fieldset class="bk-screen" data-screen="3" hidden>
            <h2 class="bk-q">A little about your work.</h2>
            <div class="bk-field" data-field="customers">
              <p class="bk-sub">Is your work mostly for homeowners, or builder and contractor accounts?</p>
              <div class="bk-cards" data-name="customers" data-radio>
                <button type="button" class="bk-card" data-value="Mostly homeowners">Mostly homeowners</button>
                <button type="button" class="bk-card" data-value="Mostly builder & contractor">Mostly builder &amp; contractor</button>
                <button type="button" class="bk-card" data-value="A mix">A mix</button>
              </div>
            </div>
            <div class="bk-field" data-field="jobs">
              <p class="bk-sub bk-sub--gap">Roughly how many kitchens or baths a month?</p>
              <div class="bk-cards bk-cards--row" data-name="jobs" data-radio>
                <button type="button" class="bk-card" data-value="1–2">1–2</button>
                <button type="button" class="bk-card" data-value="3–5">3–5</button>
                <button type="button" class="bk-card" data-value="6–10">6–10</button>
                <button type="button" class="bk-card" data-value="10+">10+</button>
              </div>
            </div>
            <div class="bk-nav"><button type="button" class="bk-back" data-back>← Back</button><button type="button" class="btn btn--primary" data-next>Continue <span aria-hidden="true">→</span></button></div>
          </fieldset>

          <!-- 4 — THE OBSTACLE (optional) -->
          <fieldset class="bk-screen" data-screen="4" hidden>
            <h2 class="bk-q"><span data-first>There</span>, what’s the one thing about getting found and getting picked online that’s eating at you most? <span class="bk-opt">(optional)</span></h2>
            <p class="bk-why">Don’t tidy it up. Give me the real version, in your own words. It’s the first thing I read before we talk.</p>
            <textarea class="bk-input" name="obstacle" rows="4"></textarea>
            <div class="bk-nav"><button type="button" class="bk-back" data-back>← Back</button><button type="button" class="btn btn--primary btn--lg" data-submit>Book my session <span aria-hidden="true">→</span></button></div>
            <p class="bk-form__status mono" data-book-status hidden></p>
          </fieldset>

          <!-- 5 — CALENDAR (full width) -->
          <fieldset class="bk-screen bk-screen--cal" data-screen="5" hidden>
            <h2 class="bk-cal__h">Got your details. Pick a time that works.</h2>
            <div class="bk-cal__widget" data-calendly></div>
            <a class="bk-cal__direct" href={site.bookingUrl} target="_blank" rel="noopener">Calendar not loading? Open it in a new tab →</a>
          </fieldset>

          <!-- honeypot -->
          <div class="honeypot" aria-hidden="true">
            <label for="company">Company (leave blank)</label>
            <input id="company" name="company" type="text" tabindex="-1" autocomplete="off" />
          </div>
        </form>
      </div>
    </section>
  </div>

  <!-- CONFIRMATION (after Calendly schedules) -->
  <section class="section bk-done" data-book-done hidden>
    <div class="container container--narrow">
      <p class="eyebrow">You’re on the books</p>
      <h2 class="bk-done__h">You’re on the books, <span data-first>there</span>.</h2>
      <p class="bk-done__p">Check your email for the time and the call link. Before we talk, I’ll dig into your business’s setup so we don’t waste a minute playing catch-up.</p>
      <p class="bk-done__sig">See you then.<br />— Shane</p>
    </div>
  </section>
</BareLayout>

<script>
  import { site } from '../data/site.config';
  import { track } from '../utils/track.js';
  const bookingUrl = site.bookingUrl;

  const form = document.querySelector<HTMLFormElement>('[data-book-form]');
  const flow = document.querySelector<HTMLElement>('[data-book-flow]');
  const done = document.querySelector<HTMLElement>('[data-book-done]');
  const status = document.querySelector<HTMLElement>('[data-book-status]');
  const dots = Array.from(document.querySelectorAll<HTMLElement>('.bk-dot'));
  const progRow = document.querySelector<HTMLElement>('[data-prog-row]');

  // Answers persist here for radios; text/textarea values live in the DOM (the
  // form is never reset between screens), and are read from the whole form at submit.
  const answers: Record<string, string> = {};

  if (form) {
    const screens = Array.from(form.querySelectorAll<HTMLElement>('.bk-screen'));
    const total = screens.length; // 0..5
    let i = 0;

    const setFirst = (name: string) => {
      document.querySelectorAll<HTMLElement>('[data-first]').forEach((el) => { el.textContent = name; });
    };

    // ---- visible validation (no silent shakes) ----
    const fieldWrap = (name: string) => form.querySelector<HTMLElement>(`[data-field="${name}"]`);
    function showErr(name: string, msg: string) {
      const wrap = fieldWrap(name);
      if (!wrap) return;
      wrap.classList.add('bk-field--err');
      let m = wrap.querySelector<HTMLElement>('.bk-err');
      if (!m) { m = document.createElement('p'); m.className = 'bk-err'; m.setAttribute('role', 'alert'); wrap.appendChild(m); }
      m.textContent = msg;
    }
    function clearErr(name: string) {
      const wrap = fieldWrap(name);
      if (!wrap) return;
      wrap.classList.remove('bk-field--err');
      wrap.querySelector('.bk-err')?.remove();
    }
    const shake = (screen: HTMLElement) => { screen.classList.remove('bk-screen--err'); void screen.offsetWidth; screen.classList.add('bk-screen--err'); };

    // read every text field across the WHOLE form (values persist on hidden screens)
    const collectAll = () => {
      form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input[name], textarea[name]').forEach((f) => {
        if (f.name === 'company') return;
        if ((f as HTMLInputElement).type === 'radio' || (f as HTMLInputElement).type === 'checkbox') return;
        answers[f.name] = f.value.trim();
      });
    };

    // ---- persistence: save every answer so the form NEVER resets between pages
    //      (or on any accidental reload). Restored on load, cleared after booking.
    const STORE = 'kw_book_v1';
    const persist = () => { try { collectAll(); sessionStorage.setItem(STORE, JSON.stringify(answers)); } catch { /* ignore */ } };
    const restore = () => {
      let saved: Record<string, string> = {};
      try { saved = JSON.parse(sessionStorage.getItem(STORE) || '{}'); } catch { return; }
      Object.assign(answers, saved);
      Object.entries(saved).forEach(([k, v]) => {
        const el = form.querySelector<HTMLInputElement | HTMLTextAreaElement>(`[name="${k}"]`);
        if (el && typeof v === 'string') el.value = v;
      });
      form.querySelectorAll<HTMLElement>('[data-radio]').forEach((g) => {
        const val = saved[g.dataset.name!];
        if (val) g.querySelectorAll<HTMLElement>('.bk-card').forEach((c) => c.classList.toggle('is-on', c.dataset.value === val));
      });
      if (saved.name) setFirst(saved.name);
    };

    // validate one screen; returns true if OK, else shows messages + shakes
    const validScreen = (screen: HTMLElement) => {
      let ok = true;
      screen.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input[name], textarea[name]').forEach((f) => {
        if (f.name === 'company') return;
        if (!f.required) return;
        const name = (f.closest('[data-field]') as HTMLElement)?.dataset.field || f.name;
        if (!f.value.trim()) { showErr(name, 'Please fill this in to continue.'); ok = false; }
        else if ((f as HTMLInputElement).type === 'email' && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(f.value)) { showErr(name, 'That email doesn’t look right.'); ok = false; }
        else clearErr(name);
      });
      // required single-choice card groups
      screen.querySelectorAll<HTMLElement>('[data-radio]').forEach((g) => {
        const name = g.dataset.name!;
        if (!g.querySelector('.is-on')) { showErr(name, 'Pick an option to continue.'); ok = false; }
        else clearErr(name);
      });
      if (!ok) shake(screen);
      return ok;
    };

    const updateDots = () => {
      const onCal = i >= total - 1;
      if (progRow) progRow.style.display = onCal ? 'none' : '';
      const filled = i >= 1 && i <= dots.length ? i : (i > dots.length ? dots.length : 0);
      dots.forEach((d, idx) => d.classList.toggle('is-on', idx < filled));
    };

    const show = (n: number) => {
      i = Math.max(0, Math.min(total - 1, n));
      screens.forEach((s, idx) => { s.hidden = idx !== i; });
      updateDots();
      if (i === total - 1) initCalendly();
      const focusable = screens[i].querySelector<HTMLElement>('input:not([hidden]), textarea, select');
      requestAnimationFrame(() => focusable?.focus());
      window.scrollTo({ top: 0, behavior: 'smooth' });
    };

    const advance = () => {
      if (i === 1) setFirst((form.querySelector<HTMLInputElement>('[name="name"]')?.value || '').trim());
      show(i + 1);
    };

    // single-choice cards: select one (no auto-advance — screen 3 has two groups)
    form.querySelectorAll<HTMLElement>('[data-radio]').forEach((group) => {
      group.querySelectorAll<HTMLButtonElement>('.bk-card').forEach((card) => {
        card.addEventListener('click', () => {
          group.querySelectorAll('.bk-card').forEach((c) => c.classList.remove('is-on'));
          card.classList.add('is-on');
          answers[group.dataset.name!] = card.dataset.value!;
          clearErr(group.dataset.name!);
          persist();
        });
      });
    });

    // clear error + persist as the user types
    form.querySelectorAll<HTMLInputElement>('input[name], textarea[name]').forEach((f) => {
      f.addEventListener('input', () => { clearErr((f.closest('[data-field]') as HTMLElement)?.dataset.field || f.name); persist(); });
    });

    const doSubmit = () => {
      const last = screens.find((s) => s.dataset.screen === '4')!;
      if (!validScreen(last)) return;               // obstacle is optional, so this passes
      if ((form.querySelector<HTMLInputElement>('[name="company"]')?.value || '').trim()) return; // honeypot

      collectAll(); // pull every text value from the whole form, plus radios already in `answers`

      // send the lead to Web3Forms — client-side FormData (no preflight), fire-and-forget
      const fd = new FormData();
      fd.append('access_key', site.web3formsKey);
      fd.append('from_name', 'Kitchen Websites');
      fd.append('subject', `📅 Session request — ${answers.website || answers.name || 'new owner'}`);
      fd.append('Name', answers.name || '');
      fd.append('email', answers.email || '');
      fd.append('Phone', answers.mobile || '');
      fd.append('Website / business & city', answers.website || '');
      fd.append('Customer mix', answers.customers || '');
      fd.append('Jobs / month', answers.jobs || '');
      if (answers.obstacle) fd.append('Biggest gripe', answers.obstacle);
      const params = new URLSearchParams(window.location.search);
      if (params.get('from')) fd.append('Came from', String(params.get('from')));
      fetch('https://api.web3forms.com/submit', { method: 'POST', body: fd }).catch(() => { /* best-effort */ });
      (window as any).kwTrack?.('LeadQualified', { via: 'session-funnel' });

      try { sessionStorage.removeItem(STORE); } catch { /* ignore */ }
      show(i + 1); // → Calendly calendar, immediately
    };

    form.addEventListener('click', (e) => {
      const t = e.target as HTMLElement;
      if (t.closest('[data-next]')) { if (i === 0 || validScreen(screens[i])) advance(); }
      else if (t.closest('[data-back]')) show(i - 1);
      else if (t.closest('[data-submit]')) doSubmit();
    });

    form.addEventListener('keydown', (e) => {
      if (e.key !== 'Enter') return;
      if ((e.target as HTMLElement).tagName === 'TEXTAREA') return;
      e.preventDefault(); // Enter must never natively submit / reload the page
      if (i < total - 1) { if (i === 0 || validScreen(screens[i])) advance(); }
    });

    // hard safety net: the form can never natively submit (which would reload + reset it)
    form.addEventListener('submit', (e) => { e.preventDefault(); });

    // ---- Calendly inline embed (loaded lazily on the calendar screen) ----
    function initCalendly() {
      const host = document.querySelector<HTMLElement>('[data-calendly]');
      if (!host || host.dataset.ready) return;
      const w = window as any;
      const go = () => {
        if (!w.Calendly) return;
        host.dataset.ready = '1';
        w.Calendly.initInlineWidget({
          url: bookingUrl,
          parentElement: host,
          prefill: { name: answers.name || '', email: answers.email || '' },
        });
      };
      if (w.Calendly) { go(); return; }
      if (!document.querySelector('link[data-calendly-css]')) {
        const link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = 'https://assets.calendly.com/assets/external/widget.css';
        link.setAttribute('data-calendly-css', '');
        document.head.appendChild(link);
      }
      const s = document.createElement('script');
      s.src = 'https://assets.calendly.com/assets/external/widget.js';
      s.async = true;
      s.onload = go;
      document.body.appendChild(s);
    }

    // Calendly messages: keep the embed sized to its content (no inner scroll),
    // and swap to the confirmation once a time is picked.
    window.addEventListener('message', (e) => {
      const data = (e.data as any);
      // auto-resize: grow/shrink the container to exactly fit the calendar
      if (data?.event === 'calendly.page_height' && data.payload?.height) {
        const host = document.querySelector<HTMLElement>('[data-calendly]');
        if (host) host.style.height = data.payload.height;
        return;
      }
      if (data?.event === 'calendly.event_scheduled') {
        (window as any).kwTrack?.('CallBooked', { via: 'calendly' });
        track('CallBooked');
        setFirst((answers.name as string) || '');
        if (flow) flow.hidden = true;
        if (done) done.hidden = false;
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    });

    restore();   // refill anything saved from a previous visit / before a reload
    show(0);
  }
</script>

<style>
  /* progress dots — gold fill, no numbers */
  .bk-prog { display: flex; justify-content: center; flex-wrap: wrap; gap: var(--space-2); padding: var(--space-8) var(--gutter) 0; }
  .bk-dot { width: 9px; height: 9px; border-radius: 999px; background: var(--line); transition: background 240ms, transform 240ms; }
  .bk-dot.is-on { background: var(--accent); transform: scale(1.15); }

  .bk-funnel { min-height: calc(100vh - 9rem); display: grid; align-items: center; padding-block: var(--space-8); }
  .bk-form { text-align: center; }
  .bk-screen { border: 0; padding: 0; margin: 0; min-height: 18rem; animation: bk-in 320ms cubic-bezier(.2,.7,.2,1); }
  @keyframes bk-in { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
  .bk-screen--err { animation: bk-shake 320ms; }
  @keyframes bk-shake { 10%,90%{transform:translateX(-1px)} 30%,70%{transform:translateX(3px)} 50%{transform:translateX(-4px)} }

  .bk-intro__h1 { margin-top: var(--space-4); font-size: var(--fs-h2); }
  .bk-intro__lede { margin: var(--space-5) auto 0; font-family: var(--font-serif); font-size: var(--fs-bodyL); line-height: 1.7; color: var(--ink); max-width: 54ch; }
  .bk-intro__sub { margin: var(--space-4) auto 0; font-family: var(--font-serif); font-size: var(--fs-bodyL); color: var(--ink-70); max-width: 54ch; }

  .bk-q { font-size: var(--fs-h4); line-height: 1.3; max-width: 40ch; margin-inline: auto; }
  .bk-opt { font-size: var(--fs-body); font-weight: var(--fw-body); color: var(--ink-50); }
  .bk-sub { margin: var(--space-4) auto 0; font-family: var(--font-serif); font-size: var(--fs-bodyL); color: var(--ink-70); max-width: 54ch; }
  .bk-sub--gap { margin-top: var(--space-8); }
  .bk-why { margin: var(--space-3) auto 0; font-style: italic; font-size: var(--fs-body); color: var(--ink-50); max-width: 56ch; }

  .bk-input { margin: var(--space-5) auto 0; width: 100%; max-width: 32rem; font-family: var(--font-body); font-size: var(--fs-bodyL); padding: var(--space-4); border: var(--rule-thick) solid var(--line); border-radius: var(--radius-sm); background: #fff; color: var(--ink); }
  .bk-input:focus-visible { outline: none; border-color: var(--ink); }
  textarea.bk-input { resize: vertical; line-height: 1.5; }

  /* stacked labeled fields (contact screen) */
  .bk-fields { margin: var(--space-5) auto 0; display: grid; gap: var(--space-4); max-width: 32rem; text-align: left; }
  .bk-field { display: block; }
  .bk-label { display: block; font-family: var(--font-body); font-size: var(--fs-body-sm); font-weight: var(--fw-body-semi); color: var(--ink-70); margin-bottom: var(--space-2); }
  .bk-fields .bk-input { margin-top: 0; max-width: none; }

  /* tap-to-select cards */
  .bk-cards { margin: var(--space-5) auto 0; display: grid; gap: var(--space-3); max-width: 32rem; }
  .bk-cards--row { grid-template-columns: repeat(2, 1fr); }
  @media (min-width: 34em) { .bk-cards--row { grid-template-columns: repeat(4, 1fr); } }
  .bk-card { text-align: center; font-family: var(--font-body); font-size: var(--fs-bodyL); padding: var(--space-4); border: var(--rule-thick) solid var(--line); border-radius: var(--radius-sm); background: #fff; color: var(--ink); cursor: pointer; min-height: 52px; display: flex; align-items: center; justify-content: center; transition: border-color 120ms, background 120ms, transform 120ms; }
  .bk-card:hover { border-color: var(--ink-50); }
  .bk-card.is-on { border-color: var(--ink); background: var(--accent-wash, color-mix(in srgb, var(--accent) 16%, #fff)); }

  /* validation */
  .bk-field--err .bk-input, .bk-field--err .bk-card { border-color: var(--warn); }
  .bk-err { margin-top: var(--space-2); font-size: var(--fs-body-sm); font-weight: var(--fw-body-semi); color: var(--warn); }

  .bk-nav { margin-top: var(--space-8); display: flex; align-items: center; justify-content: center; gap: var(--space-4); }
  .bk-back { background: none; border: 0; padding: var(--space-2); color: var(--ink-50); font-size: var(--fs-body); cursor: pointer; }
  .bk-back:hover { color: var(--ink); }
  .bk-form__status { margin-top: var(--space-4); font-size: var(--fs-caption); color: var(--ink-50); }

  /* calendar screen — full-width calendar, minimal chrome */
  .bk-screen--cal { min-height: auto; text-align: center; }
  .bk-cal__h { font-size: var(--fs-h3); margin-bottom: var(--space-6); }
  /* break the calendar out of the narrow container so it fills the screen */
  /* full-bleed calendar. The JS sizes this to Calendly's reported content height
     (calendly.page_height) so the whole calendar fits with no inner scrollbar.
     The fixed height here is the pre-message fallback (generous so it still fits). */
  .bk-cal__widget { position: relative; left: 50%; transform: translateX(-50%); width: 96vw; max-width: 70rem; height: 820px; }
  .bk-cal__widget :global(iframe) { width: 100%; height: 100%; border: 0; }
  @media (max-width: 48em) { .bk-cal__widget { width: 100vw; height: 1180px; } }
  .bk-cal__direct { display: inline-block; margin-top: var(--space-5); font-size: var(--fs-body-sm); font-weight: var(--fw-body-semi); color: var(--accent-deep); }

  /* confirmation */
  .bk-done { padding-top: var(--space-12); }
  .bk-done__h { margin-top: var(--space-4); font-size: var(--fs-h2); }
  .bk-done__p { margin-top: var(--space-5); font-family: var(--font-serif); font-size: var(--fs-bodyL); line-height: 1.7; color: var(--ink); max-width: 54ch; }
  .bk-done__sig { margin-top: var(--space-8); font-family: var(--font-display); font-size: var(--fs-h4); color: var(--ink); }

  @media (prefers-reduced-motion: reduce) {
    .bk-screen, .bk-dot { animation: none; transition: none; }
  }
</style>
