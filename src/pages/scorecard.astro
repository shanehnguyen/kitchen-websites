---
/* /scorecard — The Google Scorecard. Cold-traffic HVCO: pulls a true,
   homeowner-relevant fact about the owner's Google presence, shows it next
   to a real competitor, then escalates to the free strategy session. The
   page IS the funnel — nav-less, footer-less, single goal (Scorecard spec
   §0, §6, §9). Reachable via ad / direct link only (noindex).
   The flow is driven by src/islands/scorecard/flow.ts. */
import BareLayout from '../layouts/BareLayout.astro';
import HomeContent from '../components/HomeContent.astro';
import CTAButton from '../components/CTAButton.astro';
---
<BareLayout
  title="The Google Scorecard for Kitchen & Bath"
  description="See the true, homeowner’s-eye read of your Google presence next to the businesses near you. One tap, your real listing, the three things to fix first."
  noindex={true}
  legalFooter={false}
>
  <div class="sc" data-sc-root>
    <!-- Branded, link-less logo lockup (no nav — single-goal page) -->
    <header class="sc-brand">
      <span class="sc-brand__name">Kitchen <span>Websites</span></span>
      <span class="sc-brand__by">by FlipFix Digital</span>
    </header>

    <!-- 1 — START: the cold-ad landing. Two columns on desktop: the form on the
         left, social proof on the right; stacks on mobile. -->
    <section class="sc-screen sc-start" data-sc-screen="start">
      <div class="sc-wrap sc-start__hero">
        <div class="sc-start__main">
          <p class="eyebrow">Free Google check · Kitchen &amp; bath only</p>
          {/* MESSAGE MATCH: this headline must match the running ad word for word. Swap this one line. */}
          <h1 class="sc-start__h1" data-focus tabindex="-1">Think you show up on Google?</h1>
          <p class="sc-start__subhead">Most kitchen &amp; bath owners assume they do. In 60 seconds you’ll know for sure.</p>
          <p class="sc-start__sub">Right now a homeowner is deciding between you and the business next to you on Google. Lose that comparison and a thirty thousand dollar kitchen walks out the door before you knew it was up for grabs.</p>

          <div class="sc-intrigue">
            <p class="sc-intrigue__lead"><strong>Type your name and in 60 seconds you’ll see:</strong></p>
            <ul class="sc-intrigue__list">
              <li>Where you rank on the Google map for your area.</li>
              <li>Who your top competitors are, by name.</li>
              <li>The exact steps to fix your Google Business Profile and climb the rankings.</li>
              <li>The steps to fix your website so more homeowners turn into booked jobs.</li>
            </ul>
          </div>

          {/* Demo: input is styled but non-functional. "Check my Google" carries the typed
              value into the real autocomplete step. Live autocomplete drops in on this same input later. */}
          <form class="sc-start__action" data-start-form>
            <input class="sc-input" type="text" placeholder="Start typing your business name…" aria-label="Your business name" autocomplete="off" data-start-input />
            <button type="submit" class="btn btn--primary btn--lg" data-start>Check my Google <span aria-hidden="true">→</span></button>
          </form>
          {/* ⚠️ DEMO placeholder "100+" figure — replace with an accurate count
              before running traffic (an unsubstantiated claim is an FTC/advertising risk). */}
          <div class="sc-usedby">
            <span class="sc-usedby__stars" aria-hidden="true">★★★★★</span>
            <span class="sc-usedby__text">Used by <strong>100+</strong> kitchen &amp; bath professionals</span>
          </div>
        </div>

        {/* RIGHT RAIL: the 5×5 ranking-map visual. Illustrative example, not this
            visitor's data. */}
        <aside class="sc-start__proof" aria-label="Your ranking map">
          <figure class="sc-start__mapcard">
            <p class="sc-start__mappoint">These are the rankings of the real kitchen &amp; bath pros in the Sykesville area <span aria-hidden="true">↓</span></p>
            <img class="sc-start__mapimg" src="/assets/images/5x5map.png" alt="Example 5×5 map grid showing where the top kitchen and bath businesses rank across the Sykesville area" loading="lazy" />
          </figure>
        </aside>
      </div>
    </section>

    <!-- 2 — IDENTIFY -->
    <section class="sc-screen" data-sc-screen="identify" hidden>
      <div class="sc-wrap">
        <h2 class="sc-h" data-focus tabindex="-1">Start typing your business name.</h2>
        <p class="sc-sub">Pick your listing so I’m reading the right one. It pulls your public Google data, nothing to sign up for.</p>
        <p class="sc-identify__momentum">Your map and your numbers are one tap away.</p>
        <div class="sc-ac">
          <input class="sc-input" data-ac-input type="text" autocomplete="off" placeholder="e.g. your business name" aria-label="Your business name" />
          <div class="sc-ac__list" data-ac-list hidden></div>
        </div>
        <p class="sc-altlink"><a href="#" data-help-link>Can’t find your business? That might be the finding. Tap here.</a></p>
      </div>
    </section>

    <!-- 2b — ENGAGE QUESTIONS. Shown the instant a business is picked; the audit
         is already running behind these. Framed as tuning the report (never as a
         stall). One tap each, auto-advances. Answers ride into the lead. -->
    <section class="sc-screen" data-sc-screen="q1" hidden>
      <div class="sc-wrap">
        <p class="eyebrow">So I read your Google right</p>
        <h2 class="sc-h" data-focus tabindex="-1">What are you most known for?</h2>
        <p class="sc-sub">Choose whatever applies best.</p>
        <div class="sc-choices" data-q1-choices>
          <button type="button" class="sc-choice" data-value="Kitchen remodeling">Kitchen remodeling</button>
          <button type="button" class="sc-choice" data-value="Bathroom remodeling">Bathroom remodeling</button>
          <button type="button" class="sc-choice" data-value="Countertops &amp; fabrication">Countertops &amp; fabrication</button>
          <button type="button" class="sc-choice" data-value="Cabinets">Cabinets</button>
          <button type="button" class="sc-choice" data-value="Showroom / dealer">Showroom / dealer</button>
          <button type="button" class="sc-choice" data-value="Something else in kitchen &amp; bath">Something else in kitchen &amp; bath</button>
        </div>
      </div>
    </section>

    <section class="sc-screen" data-sc-screen="q2" hidden>
      <div class="sc-wrap">
        <p class="eyebrow">One more</p>
        <h2 class="sc-h" data-focus tabindex="-1">How’s the phone been lately?</h2>
        <div class="sc-choices" data-q2-choices>
          <button type="button" class="sc-choice" data-value="Slammed, can barely keep up">Slammed, can barely keep up</button>
          <button type="button" class="sc-choice" data-value="Steady, but it should be better">Steady, but it should be better</button>
          <button type="button" class="sc-choice" data-value="Quieter than it should be">Quieter than it should be</button>
        </div>
      </div>
    </section>

    <!-- 3 — LOADING -->
    <section class="sc-screen sc-loading" data-sc-screen="loading" hidden>
      <div class="sc-wrap">
        <div class="sc-spinner" aria-hidden="true"></div>
        <div class="sc-load__step" data-load-step>
          <p class="sc-load__status mono" data-load-status aria-live="polite"></p>
          <p class="sc-load__priming" data-load-priming></p>
        </div>
        <p class="sc-load__eta">This takes about 15 seconds, hang tight while I pull your Google.</p>
      </div>
    </section>

    <!-- 4 — HOOK (one true fact, before the gate) -->
    <section class="sc-screen sc-hookscreen" data-sc-screen="hook" hidden>
      <div class="sc-wrap">
        <p class="sc-hook" data-hook data-focus tabindex="-1"></p>
        <button type="button" class="btn btn--primary btn--lg" data-hook-next>See the full scorecard <span aria-hidden="true">→</span></button>
        <p class="sc-hook__micro mono">All three competitors, plus the three things to fix first.</p>
      </div>
    </section>

    <!-- 5 — EMAIL GATE -->
    <section class="sc-screen" data-sc-screen="gate" hidden>
      <div class="sc-wrap">
        <h2 class="sc-h" data-focus tabindex="-1">Where do I send the full scorecard?</h2>
        <p class="sc-sub">The side-by-side with all three competitors and the three fixes. You get it on the next screen, and a copy by email.</p>
        <form class="sc-form" data-gate-form novalidate>
          <div class="field">
            <label for="sc-firstname">First name</label>
            <input id="sc-firstname" name="firstName" type="text" autocomplete="given-name" placeholder="So I can make it personal" />
          </div>
          <div class="field">
            <label for="sc-email">Email</label>
            <input id="sc-email" name="email" type="email" autocomplete="email" required />
          </div>
          <label class="sc-consent">
            <input type="checkbox" name="consent" required />
            <span>Follow up with me about my Google, and the occasional useful tip. Unsubscribe anytime. <a href="/privacy" target="_blank" rel="noopener">Privacy</a>.</span>
          </label>
          <!-- honeypot. A CHECKBOX, not a text input: browser autofill and
               password managers fill TEXT fields (name/email/company/etc.) and
               were dumping a value into the old text trap, silently blocking
               real submissions. Nothing auto-ticks a checkbox. -->
          <div class="honeypot" aria-hidden="true">
            <input id="sc-hp" name="hp_confirm" type="checkbox" tabindex="-1" autocomplete="off" aria-hidden="true" />
          </div>
          <button type="submit" class="btn btn--primary btn--lg">See the full scorecard <span aria-hidden="true">→</span></button>
          <p class="sc-status mono" data-gate-status hidden></p>
        </form>
      </div>
    </section>

    <!-- 6 — FULL RESULT: audit (rendered by flow.ts) ends at the owner-only
         tease, then the entire homepage follows: hero video → letter → … →
         FAQ → footer. -->
    <section class="sc-screen sc-screen--result" data-sc-screen="result" hidden>
      <div class="sc-wrap" data-result-host></div>
      <!-- featured video the "More info ↓" prompt points to, right after the audit -->
      <div class="sc-reel">
        <div class="sc-reel__video">
          <video class="sc-reel__media" playsinline preload="metadata" poster="/video/kitchenwebsites-video2-poster.jpg" data-src="/video/kitchenwebsites-video2.mp4"></video>
          <button type="button" class="sc-reel__play" aria-label="Play video"><span aria-hidden="true">▶</span></button>
        </div>
        <div class="sc-reel__cta">
          <CTAButton href="/book" label="Claim your free strategy session" event="Scorecard:ReelToBook" size="lg" />
        </div>
      </div>
      <div class="sc-home">
        <HomeContent hero={false} />
      </div>
    </section>

    <!-- NOT FOUND — exact-name help (replaces manual capture; reachable from the
         "can't find it" link and whenever a lookup can't resolve the listing) -->
    <section class="sc-screen" data-sc-screen="notfound" hidden>
      <div class="sc-wrap">
        <h2 class="sc-h" data-focus tabindex="-1">I couldn’t pull that one up.</h2>
        <p class="sc-sub">Nine times out of ten it’s the name. Search the <strong>exact</strong> name as it shows on your Google Business Profile — the one a customer sees on Google Maps — and pick your listing from the list that drops down.</p>
        <ul class="sc-tips">
          <li>Spell it exactly the way it appears on Google.</li>
          <li>Leave off your city, “LLC,” and any extra words you’ve added.</li>
          <li>Start typing, then tap your business in the list.</li>
        </ul>
        <button type="button" class="btn btn--primary btn--lg" data-notfound-retry>Try again <span aria-hidden="true">→</span></button>
      </div>
    </section>
  </div>
</BareLayout>

<script>
  import { init } from '../islands/scorecard/flow.ts';
  init();

  // Featured reel under the audit: load + play only on click.
  const reel = document.querySelector('.sc-reel__video');
  const reelVid = reel?.querySelector('video');
  const reelBtn = reel?.querySelector('.sc-reel__play');
  reelBtn?.addEventListener('click', () => {
    const src = reelVid?.getAttribute('data-src');
    if (reelVid && src && !reelVid.getAttribute('src')) reelVid.src = src;
    if (reelVid) { reelVid.controls = true; reelVid.play().catch(() => {}); }
    reel?.classList.add('is-playing');
  });
</script>

<!-- is:global is REQUIRED: the result screen (verdict, table, leaks, CTA) is
     built at runtime via innerHTML in flow.ts, and Astro scoped styles only
     attach to template elements. All selectors are sc- namespaced, so global
     is safe and keeps the injected DOM on the site's design system. -->
<style is:global>
  .sc { min-height: 100dvh; }
  /* single-goal funnel: no persistent CTA bar, even from the embedded homepage */
  .smcta { display: none; }
  .sc-wrap { max-width: 42rem; margin-inline: auto; padding: var(--space-8) var(--gutter) var(--space-16); }
  /* the result runs wider than the question screens so the audit's two columns
     break out of the narrow reading column and the boxes get real width */
  .sc-wrap[data-result-host] { max-width: 60rem; }

  /* branded, link-less logo lockup — matches the homepage wordmark */
  .sc-brand { display: flex; flex-direction: column; align-items: center; gap: 2px; padding: var(--space-6) var(--gutter) 0; text-align: center; line-height: 1; }
  .sc-brand__name { font-family: var(--font-display); font-weight: var(--fw-display); font-size: 1.3rem; text-transform: uppercase; letter-spacing: 0.01em; color: var(--ink); }
  .sc-brand__name span { color: var(--accent); }
  .sc-brand__by { font-family: var(--font-body); font-size: 0.6rem; letter-spacing: var(--tracking-caps); text-transform: uppercase; font-weight: var(--fw-body-semi); color: var(--ink-50); }
  .sc-screen { animation: sc-in 320ms cubic-bezier(.2,.7,.2,1); }
  @keyframes sc-in { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }

  /* ---- START: cold-ad landing. Two columns on desktop (form left, proof right).
     Wider wrap + a fixed-width proof rail so the left column (headline/form)
     gets real breathing room instead of splitting the page down the middle. ---- */
  .sc-start__hero { padding-top: var(--space-6); padding-bottom: var(--space-12); display: grid; gap: var(--space-8); }
  @media (min-width: 54em) {
    .sc-start .sc-wrap { max-width: 80rem; }
    .sc-start__hero { grid-template-columns: minmax(0, 1fr) 24rem; align-items: start; gap: var(--space-12); }
  }
  /* boxed headline — a highlighted card around the H1, same accent-top-rule
     treatment as the site's stat/grade cards, so the headline reads as the
     one thing on the page you're meant to stop on. */
  .sc-start__h1 {
    margin-top: var(--space-3); display: inline-block; max-width: 40rem;
    padding: var(--space-5) var(--space-6);
    background: var(--bg-raised); border: var(--rule-width) solid var(--line); border-top: var(--rule-thick) solid var(--accent); border-radius: var(--radius-sm);
    font-family: var(--font-display); font-weight: var(--fw-display); text-transform: uppercase; letter-spacing: var(--tracking-display); font-size: var(--fs-h2); line-height: 1.15; color: var(--ink); text-wrap: balance;
  }
  /* subheadline, directly under the boxed H1 — body-large size, semibold weight */
  .sc-start__subhead { margin-top: var(--space-4); font-family: var(--font-body); font-weight: var(--fw-body-semi); font-size: var(--fs-bodyL); line-height: 1.4; color: var(--ink); max-width: 44rem; }
  .sc-start__sub { margin-top: var(--space-5); font-family: var(--font-serif); font-size: var(--fs-bodyL); line-height: 1.6; color: var(--ink-70); max-width: 44rem; }

  /* intrigue block — what the 60-second read shows, before the form */
  .sc-intrigue { margin-top: var(--space-6); max-width: 44rem; }
  .sc-intrigue__lead { font-family: var(--font-body); font-size: var(--fs-body); color: var(--ink); }
  .sc-intrigue__list { list-style: none; margin: var(--space-3) 0 0; padding: 0; display: grid; gap: var(--space-2); }
  .sc-intrigue__list li { position: relative; padding-left: var(--space-6); font-family: var(--font-body); font-size: var(--fs-body-sm); line-height: 1.5; color: var(--ink-70); }
  .sc-intrigue__list li::before { content: "→"; position: absolute; left: 0; color: var(--accent-deep); font-weight: var(--fw-body-bold); }

  .sc-start__action { margin-top: var(--space-6); display: grid; gap: var(--space-3); max-width: 46rem; }
  .sc-start__action .sc-input { margin-top: 0; }
  .sc-start__action .btn { width: 100%; }
  @media (min-width: 32em) { .sc-start__action { grid-template-columns: 1fr auto; align-items: center; } .sc-start__action .btn { width: auto; } }

  /* "used by" trust line, under the form (replaces the old "Free · Kitchen and bath only" strip) */
  .sc-usedby { margin-top: var(--space-4); display: flex; align-items: center; gap: var(--space-3); flex-wrap: wrap; }
  .sc-usedby__stars { color: var(--accent-deep); letter-spacing: 2px; font-size: 1rem; line-height: 1; }
  .sc-usedby__text { font-size: var(--fs-body-sm); color: var(--ink-70); }
  .sc-usedby__text strong { color: var(--ink); font-weight: var(--fw-body-bold); }

  /* right rail — ranking-map visual on top, testimonials underneath */
  .sc-start__proof { display: grid; gap: var(--space-5); align-content: start; }
  .sc-start__mapcard { margin: 0; }
  /* big callout pointing down at the map, instead of a small caption under it */
  .sc-start__mappoint { margin: 0 0 var(--space-4); font-family: var(--font-display); font-weight: var(--fw-display); text-transform: uppercase; letter-spacing: var(--tracking-display); font-size: var(--fs-h3); line-height: 1.2; color: var(--accent-deep); text-wrap: balance; }
  .sc-start__mappoint span { display: inline-block; margin-left: var(--space-2); font-size: 1.3em; }
  .sc-start__mapimg { display: block; width: 100%; height: auto; border: var(--rule-width) solid var(--line); border-radius: var(--radius-sm); }

  .sc-h { font-size: clamp(1.6rem, 2.5vw + 1rem, 2.5rem); line-height: 1.15; }
  .sc-sub { margin-top: var(--space-4); font-family: var(--font-serif); font-size: var(--fs-bodyL); color: var(--ink-70); max-width: 52ch; }
  /* momentum line on the identify screen — slightly emphasized, not a full subhead */
  .sc-identify__momentum { margin-top: var(--space-3); font-family: var(--font-body); font-weight: var(--fw-body-semi); font-size: var(--fs-body); color: var(--ink); }

  /* autocomplete */
  .sc-ac { position: relative; margin-top: var(--space-6); }
  .sc-input { width: 100%; font-family: var(--font-body); font-size: var(--fs-bodyL); padding: var(--space-4); border: var(--rule-thick) solid var(--line); border-radius: var(--radius-sm); background: var(--bg-raised); color: var(--ink); }
  .sc-input:focus-visible { outline: none; border-color: var(--ink); }
  .sc-ac__list { margin-top: var(--space-2); display: grid; gap: 2px; border: var(--rule-width) solid var(--line); border-radius: var(--radius-sm); overflow: hidden; background: var(--line); }
  .sc-ac__item { display: flex; flex-direction: column; gap: 2px; text-align: left; padding: var(--space-4); background: #fff; border: 0; cursor: pointer; }
  .sc-ac__item:hover { background: var(--bg-raised); }
  .sc-ac__primary { font-weight: var(--fw-body-semi); color: var(--ink); }
  .sc-ac__secondary { font-size: var(--fs-body-sm); color: var(--ink-50); }
  .sc-altlink { margin-top: var(--space-5); font-size: var(--fs-body-sm); }
  .sc-altlink a { color: var(--ink-50); text-decoration: underline; }

  /* engage questions — big, single-tap choice buttons (auto-advance) */
  .sc-choices { margin-top: var(--space-6); display: grid; gap: var(--space-3); }
  .sc-choice { text-align: left; padding: var(--space-4) var(--space-5); font-family: var(--font-body); font-size: var(--fs-bodyL); font-weight: var(--fw-body-semi); color: var(--ink); background: var(--bg-raised); border: var(--rule-thick) solid var(--line); border-radius: var(--radius-sm); cursor: pointer; transition: border-color 120ms, background 120ms, transform 80ms; }
  .sc-choice:hover { border-color: var(--ink); background: var(--bg); }
  .sc-choice:active { transform: translateY(1px); }
  .sc-choice:focus-visible { outline: none; border-color: var(--ink); }

  /* exact-name help (not-found screen) */
  .sc-tips { margin: var(--space-6) 0 var(--space-8); padding: 0; list-style: none; display: grid; gap: var(--space-3); max-width: 48ch; }
  .sc-tips li { position: relative; padding-left: var(--space-6); font-size: var(--fs-body); color: var(--ink-70); line-height: 1.5; }
  .sc-tips li::before { content: "✓"; position: absolute; left: 0; color: var(--accent-deep); font-weight: var(--fw-body-bold); }

  /* loading */
  .sc-loading .sc-wrap { display: grid; place-items: center; gap: var(--space-5); min-height: 50vh; text-align: center; }
  .sc-spinner { width: 40px; height: 40px; border: 3px solid var(--line); border-top-color: var(--accent); border-radius: 999px; animation: sc-spin 800ms linear infinite; }
  @keyframes sc-spin { to { transform: rotate(360deg); } }
  .sc-loading__text { color: var(--ink-50); letter-spacing: var(--tracking-caps); }
  /* stepped loading narrative: status line + readable priming line, ≥1500ms each */
  .sc-load__step { max-width: 42ch; display: grid; gap: var(--space-3); }
  .sc-load__step.is-step-in { animation: sc-in 360ms cubic-bezier(.2,.7,.2,1); }
  .sc-load__status { color: var(--ink-50); letter-spacing: var(--tracking-caps); text-transform: uppercase; font-size: var(--fs-caption); }
  .sc-load__priming { font-family: var(--font-serif); font-size: var(--fs-bodyL); line-height: 1.55; color: var(--ink); }
  .sc-load__eta { margin-top: var(--space-2); font-size: var(--fs-body-sm); color: var(--ink-50); }

  /* hook */
  .sc-hook { font-family: var(--font-display); font-size: clamp(1.6rem, 3vw + 1rem, 2.75rem); line-height: 1.2; color: var(--ink); }
  .sc-hookscreen .btn { margin-top: var(--space-8); }
  .sc-hook__micro { margin-top: var(--space-4); font-size: var(--fs-caption); color: var(--ink-50); }

  /* forms */
  .sc-form { margin-top: var(--space-6); display: grid; gap: var(--space-5); }
  .sc-consent { display: flex; align-items: flex-start; gap: var(--space-3); font-size: var(--fs-body-sm); color: var(--ink-70); cursor: pointer; }
  .sc-consent input { width: 18px; height: 18px; margin-top: 2px; accent-color: var(--ink); flex-shrink: 0; }
  .sc-consent a { color: var(--ink); text-decoration: underline; }
  .sc-status { font-size: var(--fs-caption); color: var(--alarm); }

  /* result — verdict */
  .sc-verdict__eyebrow { margin-bottom: var(--space-2); }
  .sc-verdict__h { margin-top: var(--space-3); font-family: var(--font-display); font-weight: var(--fw-display); letter-spacing: var(--tracking-display); text-transform: uppercase; color: var(--ink); font-size: var(--fs-h2); line-height: 1.02; text-wrap: balance; }
  .sc-verdict__sub { margin-top: var(--space-4); font-family: var(--font-serif); font-size: var(--fs-bodyL); line-height: 1.6; color: var(--ink-70); }

  /* result — side-by-side table */
  .sc-tablewrap { margin-top: var(--space-8); overflow-x: auto; }
  .sc-table { width: 100%; border-collapse: collapse; font-size: var(--fs-body); }
  .sc-table th[scope="col"] { text-align: left; font-size: var(--fs-caption); text-transform: uppercase; letter-spacing: var(--tracking-caps); color: var(--ink-50); padding: var(--space-3) var(--space-3); border-bottom: var(--rule-width) solid var(--line); }
  .sc-table td, .sc-table th[scope="row"] { padding: var(--space-4) var(--space-3); border-bottom: var(--rule-width) solid var(--line); }
  .sc-table th[scope="row"] { text-align: left; font-weight: var(--fw-body-semi); color: var(--ink); }
