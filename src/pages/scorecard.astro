---
/* /scorecard — The Google Scorecard. Cold-traffic HVCO: pulls a true,
   homeowner-relevant fact about the owner's Google presence, shows it next
   to a real competitor, then escalates to the free strategy session. The
   page IS the funnel — nav-less, footer-less, single goal (Scorecard spec
   §0, §6, §9). Reachable via ad / direct link only (noindex).
   The flow is driven by src/islands/scorecard/flow.ts. */
import BareLayout from '../layouts/BareLayout.astro';
import HomeContent from '../components/HomeContent.astro';
import Footer from '../components/Footer.astro';
const minutes = 30;
---
<BareLayout
  title="The Google Scorecard for Kitchen & Bath"
  description="See the true, homeowner's-eye read of your Google presence next to the shops near you. One tap, your real listing, the three things to fix first."
  noindex={true}
  legalFooter={false}
>
  <div class="sc" data-sc-root>
    <!-- Branded, link-less logo lockup (no nav — single-goal page) -->
    <header class="sc-brand">
      <span class="sc-brand__name">Kitchen <span>Websites</span></span>
      <span class="sc-brand__by">by FlipFix Digital</span>
    </header>

    <!-- 1 — START: the cold-ad landing state (single page: hero → stats → footer) -->
    <section class="sc-screen sc-start" data-sc-screen="start">
      <div class="sc-wrap sc-start__hero">
        <p class="eyebrow">Free Google check · Kitchen &amp; bath only</p>
        {/* MESSAGE MATCH: this headline must match the running ad word for word. Swap this one line. */}
        <h1 class="sc-start__h1" data-focus tabindex="-1">Is your Google better than your competitors?</h1>
        <p class="sc-start__sub">Right now a homeowner is sizing you up against the shop next to you on Google. Lose that one, and it’s a twenty to thirty thousand dollar kitchen walking out the door before you ever knew it was up for grabs.</p>
        <p class="sc-start__cue">Type your business name and I’ll show you exactly where you stand.</p>
        {/* Demo: input is styled but non-functional. "Check my Google" carries the typed
            value into the real autocomplete step. Live autocomplete drops in on this same input later. */}
        <form class="sc-start__action" data-start-form>
          <input class="sc-input" type="text" placeholder="Start typing your business name…" aria-label="Your business name" autocomplete="off" data-start-input />
          <button type="submit" class="btn btn--primary btn--lg" data-start>Check my Google <span aria-hidden="true">→</span></button>
        </form>

        <ul class="sc-start__stats">
          <li><span class="sc-start__stat-num">97%</span><span class="sc-start__stat-cap">of homeowners read your reviews before they pick a local business.</span></li>
          <li><span class="sc-start__stat-num">92%</span><span class="sc-start__stat-cap">won’t consider a shop under four stars, no matter how good the work.</span></li>
          <li><span class="sc-start__stat-num">2.7×</span><span class="sc-start__stat-cap">more likely to be trusted when your Google profile is complete.</span></li>
        </ul>
      </div>

      <Footer />
    </section>

    <!-- 2 — IDENTIFY -->
    <section class="sc-screen" data-sc-screen="identify" hidden>
      <div class="sc-wrap">
        <h2 class="sc-h" data-focus tabindex="-1">Start typing your business name.</h2>
        <p class="sc-sub">Pick your own listing from the list so I’m reading the right one.</p>
        <div class="sc-ac">
          <input class="sc-input" data-ac-input type="text" autocomplete="off" placeholder="e.g. your shop’s name" aria-label="Your business name" />
          <div class="sc-ac__list" data-ac-list hidden></div>
        </div>
        <p class="sc-altlink"><a href="#" data-manual-link>Can’t find your business? Run it by hand instead.</a></p>
      </div>
    </section>

    <!-- 3 — LOADING -->
    <section class="sc-screen sc-loading" data-sc-screen="loading" hidden>
      <div class="sc-wrap">
        <div class="sc-spinner" aria-hidden="true"></div>
        <p class="sc-loading__text mono">Pulling your Google…</p>
      </div>
    </section>

    <!-- 4 — HOOK (one true fact, before the gate) -->
    <section class="sc-screen sc-hookscreen" data-sc-screen="hook" hidden>
      <div class="sc-wrap">
        <p class="sc-hook" data-hook data-focus tabindex="-1"></p>
        <button type="button" class="btn btn--primary btn--lg" data-hook-next>See the full scorecard <span aria-hidden="true">→</span></button>
        <p class="sc-hook__micro mono">All three competitors, plus the three things to fix first.</p>
      </div>
    </section>

    <!-- 5 — EMAIL GATE -->
    <section class="sc-screen" data-sc-screen="gate" hidden>
      <div class="sc-wrap">
        <h2 class="sc-h" data-focus tabindex="-1">Where do I send the full scorecard?</h2>
        <p class="sc-sub">The side-by-side with all three competitors and the three fixes. You get it on the next screen, and a copy by email.</p>
        <form class="sc-form" data-gate-form novalidate>
          <div class="field">
            <label for="sc-firstname">First name</label>
            <input id="sc-firstname" name="firstName" type="text" autocomplete="given-name" placeholder="So I can make it personal" />
          </div>
          <div class="field">
            <label for="sc-email">Email</label>
            <input id="sc-email" name="email" type="email" autocomplete="email" required />
          </div>
          <label class="sc-consent">
            <input type="checkbox" name="consent" required />
            <span>Send me my scorecard and the occasional useful follow-up. Unsubscribe anytime. <a href="/privacy" target="_blank" rel="noopener">Privacy</a>.</span>
          </label>
          <div class="honeypot" aria-hidden="true">
            <label for="sc-company">Company (leave blank)</label>
            <input id="sc-company" name="company" type="text" tabindex="-1" autocomplete="off" />
          </div>
          <button type="submit" class="btn btn--primary btn--lg">See the full scorecard <span aria-hidden="true">→</span></button>
          <p class="sc-status mono" data-gate-status hidden></p>
        </form>
      </div>
    </section>

    <!-- 6 — FULL RESULT: audit (rendered by flow.ts) ends at the owner-only
         tease, then the entire homepage follows: hero video → letter → … →
         FAQ → footer. -->
    <section class="sc-screen sc-screen--result" data-sc-screen="result" hidden>
      <div class="sc-wrap" data-result-host></div>
      <div class="sc-home">
        <HomeContent hero={false} />
        <Footer />
      </div>
    </section>

    <!-- FALLBACK — MANUAL CAPTURE (API down / can't find listing) -->
    <section class="sc-screen" data-sc-screen="manual" hidden>
      <div class="sc-wrap">
        <h2 class="sc-h" data-focus tabindex="-1">Tell me your shop and I’ll run it by hand.</h2>
        <p class="sc-sub">I’ll pull your Google myself and email your scorecard within a few hours. No bot, just me.</p>
        <form class="sc-form" data-manual-form novalidate>
          <div class="field">
            <label for="sc-m-business">Business name</label>
            <input id="sc-m-business" name="business" type="text" required />
          </div>
          <div class="field">
            <label for="sc-m-city">City</label>
            <input id="sc-m-city" name="city" type="text" />
          </div>
          <div class="field">
            <label for="sc-m-email">Email</label>
            <input id="sc-m-email" name="email" type="email" autocomplete="email" required />
          </div>
          <label class="sc-consent">
            <input type="checkbox" name="consent" required />
            <span>Send me my scorecard and the occasional useful follow-up. Unsubscribe anytime. <a href="/privacy" target="_blank" rel="noopener">Privacy</a>.</span>
          </label>
          <div class="honeypot" aria-hidden="true">
            <label for="sc-m-company">Company (leave blank)</label>
            <input id="sc-m-company" name="company" type="text" tabindex="-1" autocomplete="off" />
          </div>
          <button type="submit" class="btn btn--primary btn--lg">Run my scorecard <span aria-hidden="true">→</span></button>
          <p class="sc-status mono" data-manual-status hidden></p>
        </form>
      </div>
    </section>

    <!-- MANUAL DONE -->
    <section class="sc-screen" data-sc-screen="manualDone" hidden>
      <div class="sc-wrap">
        <h2 class="sc-h" data-focus tabindex="-1">Got it. I’ll run it by hand.</h2>
        <p class="sc-sub">Your scorecard lands in your inbox within a few hours. If it’s as lopsided as most, the fastest fix is {minutes} minutes on a call.</p>
        <a class="btn btn--primary btn--lg" href="/book">Book the {minutes}-minute call <span aria-hidden="true">→</span></a>
      </div>
    </section>
  </div>
</BareLayout>

<script>
  import { init } from '../islands/scorecard/flow.ts';
  init();
</script>

<!-- is:global is REQUIRED: the result screen (verdict, table, leaks, CTA) is
     built at runtime via innerHTML in flow.ts, and Astro scoped styles only
     attach to template elements. All selectors are sc- namespaced, so global
     is safe and keeps the injected DOM on the site's design system. -->
<style is:global>
  .sc { min-height: 100dvh; }
  .sc-wrap { max-width: 42rem; margin-inline: auto; padding: var(--space-8) var(--gutter) var(--space-16); }
  /* the result runs wider than the question screens so the audit's two columns
     break out of the narrow reading column and the boxes get real width */
  .sc-wrap[data-result-host] { max-width: 60rem; }

  /* branded, link-less logo lockup — matches the homepage wordmark */
  .sc-brand { display: flex; flex-direction: column; align-items: center; gap: 2px; padding: var(--space-6) var(--gutter) 0; text-align: center; line-height: 1; }
  .sc-brand__name { font-family: var(--font-display); font-weight: var(--fw-display); font-size: 1.3rem; text-transform: uppercase; letter-spacing: 0.01em; color: var(--ink); }
  .sc-brand__name span { color: var(--accent); }
  .sc-brand__by { font-family: var(--font-body); font-size: 0.6rem; letter-spacing: var(--tracking-caps); text-transform: uppercase; font-weight: var(--fw-body-semi); color: var(--ink-50); }
  .sc-screen { animation: sc-in 320ms cubic-bezier(.2,.7,.2,1); }
  @keyframes sc-in { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }

  /* ---- START: cold-ad landing (single page: hero → stats → footer) ---- */
  .sc-start__hero { padding-top: var(--space-6); padding-bottom: var(--space-12); }
  .sc-start__h1 { margin-top: var(--space-3); font-family: var(--font-display); font-weight: var(--fw-display); text-transform: uppercase; letter-spacing: var(--tracking-display); font-size: var(--fs-h2); line-height: 1.04; color: var(--ink); text-wrap: balance; }
  .sc-start__sub { margin-top: var(--space-4); font-family: var(--font-serif); font-size: var(--fs-bodyL); line-height: 1.6; color: var(--ink-70); max-width: 54ch; }
  .sc-start__cue { margin-top: var(--space-4); font-family: var(--font-body); font-weight: var(--fw-body-semi); font-size: var(--fs-body); color: var(--ink); }
  .sc-start__action { margin-top: var(--space-5); display: grid; gap: var(--space-3); }
  .sc-start__action .sc-input { margin-top: 0; }
  .sc-start__action .btn { width: 100%; }
  @media (min-width: 32em) { .sc-start__action { grid-template-columns: 1fr auto; align-items: center; } .sc-start__action .btn { width: auto; } }
  .sc-start__micro { margin-top: var(--space-3); font-size: var(--fs-caption); color: var(--ink-50); }

  /* stat strip — homepage receipts treatment, gold numbers (real stats only) */
  .sc-start__stats { list-style: none; padding: 0; margin: var(--space-10) 0 0; display: grid; grid-template-columns: 1fr; gap: var(--space-4); }
  @media (min-width: 44em) { .sc-start__stats { grid-template-columns: repeat(3, 1fr); } }
  .sc-start__stats li { background: var(--bg-raised); border: var(--rule-width) solid var(--line); border-top: var(--rule-thick) solid var(--accent); border-radius: var(--radius-sm); padding: var(--space-5) var(--space-6); }
  .sc-start__stat-num { display: block; font-family: var(--font-display); font-weight: var(--fw-display); font-size: var(--fs-stat); line-height: 1; color: var(--accent-deep); }
  .sc-start__stat-cap { display: block; margin-top: var(--space-3); font-size: var(--fs-body-sm); line-height: 1.4; color: var(--ink-70); }

  .sc-h { font-size: clamp(1.6rem, 2.5vw + 1rem, 2.5rem); line-height: 1.15; }
  .sc-sub { margin-top: var(--space-4); font-family: var(--font-serif); font-size: var(--fs-bodyL); color: var(--ink-70); max-width: 52ch; }

  /* autocomplete */
  .sc-ac { position: relative; margin-top: var(--space-6); }
  .sc-input { width: 100%; font-family: var(--font-body); font-size: var(--fs-bodyL); padding: var(--space-4); border: var(--rule-thick) solid var(--line); border-radius: var(--radius-sm); background: var(--bg-raised); color: var(--ink); }
  .sc-input:focus-visible { outline: none; border-color: var(--ink); }
  .sc-ac__list { margin-top: var(--space-2); display: grid; gap: 2px; border: var(--rule-width) solid var(--line); border-radius: var(--radius-sm); overflow: hidden; background: var(--line); }
  .sc-ac__item { display: flex; flex-direction: column; gap: 2px; text-align: left; padding: var(--space-4); background: #fff; border: 0; cursor: pointer; }
  .sc-ac__item:hover { background: var(--bg-raised); }
  .sc-ac__primary { font-weight: var(--fw-body-semi); color: var(--ink); }
  .sc-ac__secondary { font-size: var(--fs-body-sm); color: var(--ink-50); }
  .sc-altlink { margin-top: var(--space-5); font-size: var(--fs-body-sm); }
  .sc-altlink a { color: var(--ink-50); text-decoration: underline; }

  /* loading */
  .sc-loading .sc-wrap { display: grid; place-items: center; gap: var(--space-5); min-height: 50vh; text-align: center; }
  .sc-spinner { width: 40px; height: 40px; border: 3px solid var(--line); border-top-color: var(--accent); border-radius: 999px; animation: sc-spin 800ms linear infinite; }
  @keyframes sc-spin { to { transform: rotate(360deg); } }
  .sc-loading__text { color: var(--ink-50); letter-spacing: var(--tracking-caps); }

  /* hook */
  .sc-hook { font-family: var(--font-display); font-size: clamp(1.6rem, 3vw + 1rem, 2.75rem); line-height: 1.2; color: var(--ink); }
  .sc-hookscreen .btn { margin-top: var(--space-8); }
  .sc-hook__micro { margin-top: var(--space-4); font-size: var(--fs-caption); color: var(--ink-50); }

  /* forms */
  .sc-form { margin-top: var(--space-6); display: grid; gap: var(--space-5); }
  .sc-consent { display: flex; align-items: flex-start; gap: var(--space-3); font-size: var(--fs-body-sm); color: var(--ink-70); cursor: pointer; }
  .sc-consent input { width: 18px; height: 18px; margin-top: 2px; accent-color: var(--ink); flex-shrink: 0; }
  .sc-consent a { color: var(--ink); text-decoration: underline; }
  .sc-status { font-size: var(--fs-caption); color: var(--alarm); }

  /* result — verdict */
  .sc-verdict__eyebrow { margin-bottom: var(--space-2); }
  .sc-verdict__h { margin-top: var(--space-3); font-family: var(--font-display); font-weight: var(--fw-display); letter-spacing: var(--tracking-display); text-transform: uppercase; color: var(--ink); font-size: var(--fs-h2); line-height: 1.02; text-wrap: balance; }
  .sc-verdict__sub { margin-top: var(--space-4); font-family: var(--font-serif); font-size: var(--fs-bodyL); line-height: 1.6; color: var(--ink-70); }

  /* result — side-by-side table */
  .sc-tablewrap { margin-top: var(--space-8); overflow-x: auto; }
  .sc-table { width: 100%; border-collapse: collapse; font-size: var(--fs-body); }
  .sc-table th[scope="col"] { text-align: left; font-size: var(--fs-caption); text-transform: uppercase; letter-spacing: var(--tracking-caps); color: var(--ink-50); padding: var(--space-3) var(--space-3); border-bottom: var(--rule-width) solid var(--line); }
  .sc-table td, .sc-table th[scope="row"] { padding: var(--space-4) var(--space-3); border-bottom: var(--rule-width) solid var(--line); }
  .sc-table th[scope="row"] { text-align: left; font-weight: var(--fw-body-semi); color: var(--ink); }
  .sc-num { text-align: center; font-family: var(--font-mono); font-variant-numeric: tabular-nums; }
  .sc-num--alarm { color: var(--alarm); font-weight: var(--fw-body-bold); }
  .sc-table__me { background: var(--bg-raised); }
  .sc-table__me th[scope="row"] { border-left: var(--rule-thick) solid var(--accent); }
  .sc-table__tag { display: inline-block; margin-left: var(--space-2); font-family: var(--font-mono); font-size: var(--fs-caption); text-transform: uppercase; letter-spacing: var(--tracking-caps); color: var(--accent-deep); }

  /* result — sections + graded audit */
  .sc-section { margin-top: var(--space-10); }
  .sc-eyebrow { margin-bottom: var(--space-2); }
  .sc-section__h { font-family: var(--font-display); font-weight: var(--fw-display); font-size: var(--fs-h3); text-transform: uppercase; letter-spacing: var(--tracking-display); color: var(--ink); }
  .sc-section__sub { margin-top: var(--space-2); font-size: var(--fs-body-sm); color: var(--ink-50); }
  .sc-grades { list-style: none; padding: 0; margin: var(--space-5) 0 0; display: grid; gap: var(--space-4); }
  /* two equal columns on wider screens (one column on mobile); grid-auto-rows:1fr
     forces every box to the same height so the audit reads as a clean grid */
  @media (min-width: 40em) { .sc-grades { grid-template-columns: 1fr 1fr; grid-auto-rows: 1fr; } }
  .sc-grade { height: 100%; }
  .sc-grade { padding: var(--space-5); border: var(--rule-width) solid var(--line); border-left: var(--rule-thick) solid var(--line); border-radius: var(--radius-sm); background: var(--bg-raised); }
  .sc-grade--fail { border-left-color: var(--alarm); }
  .sc-grade--warn { border-left-color: var(--accent); }
  .sc-grade__head { display: flex; align-items: center; gap: var(--space-3); flex-wrap: wrap; }
  .sc-grade__chip { font-family: var(--font-mono); font-size: var(--fs-small); font-weight: var(--fw-body-bold); text-transform: uppercase; letter-spacing: var(--tracking-caps); padding: 3px var(--space-2); border-radius: var(--radius-sm); white-space: nowrap; }
  .sc-grade--fail .sc-grade__chip { background: var(--alarm); color: var(--bg); }            /* alarm/red pill */
  .sc-grade--warn .sc-grade__chip { background: color-mix(in srgb, var(--ink) 8%, transparent); color: var(--ink-soft); border: var(--rule-width) solid var(--line); } /* muted, not tan */
  .sc-grade__label { font-family: var(--font-display); font-size: var(--fs-h4); color: var(--ink); }
  /* every metric/data line in the gold accent, like the homepage stat numbers */
  .sc-grade__value { margin-top: var(--space-3); font-family: var(--font-body); font-weight: var(--fw-body-semi); font-size: var(--fs-body); color: var(--accent-deep); }
  .sc-grade__why { margin-top: var(--space-2); color: var(--ink-70); font-size: var(--fs-body-sm); line-height: 1.55; }
  .sc-grade__fix { margin-top: var(--space-3); color: var(--ink); font-size: var(--fs-body-sm); line-height: 1.55; }
  .sc-grade__fixlabel { font-weight: var(--fw-body-bold); }
  .sc-doing { margin-top: var(--space-5); font-size: var(--fs-body-sm); color: var(--ink-70); line-height: 1.55; }
  .sc-doing__label { font-weight: var(--fw-body-bold); color: var(--ink); }

  /* ---- Rankings section: the map-grid visual ---- */
  .sc-rank__panel { margin-top: var(--space-6); display: grid; grid-template-columns: 1fr; gap: var(--space-6); align-items: center; }
  @media (min-width: 40em) { .sc-rank__panel { grid-template-columns: auto 1fr; gap: var(--space-8); } }
  /* the 3x3 geogrid */
  .sc-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; width: 100%; max-width: 17rem; margin-inline: auto; aspect-ratio: 1 / 1; padding: 10px; background: var(--bg-raised); border: var(--rule-width) solid var(--line); border-radius: var(--radius-md); }
  .sc-grid__cell { display: flex; align-items: center; justify-content: center; border-radius: var(--radius-sm); font-family: var(--font-display); font-size: var(--fs-body); font-weight: var(--fw-display); color: #fff; min-height: 0; }
  .sc-grid__cell--in { background: var(--ok, #2e7d4f); }
  .sc-grid__cell--out { background: var(--alarm); }
  .sc-grid__cell--nodata { background: color-mix(in srgb, var(--ink) 12%, transparent); color: var(--ink-50); }
  .sc-grid__cell--center { outline: 3px solid var(--ink); outline-offset: -3px; }
  .sc-grid__legend { margin-top: var(--space-4); font-size: var(--fs-caption); color: var(--ink-50); display: flex; align-items: center; flex-wrap: wrap; gap: 4px; }
  .sc-grid__key { display: inline-block; width: 12px; height: 12px; border-radius: 3px; vertical-align: middle; }
  .sc-grid__key--in { background: var(--ok, #2e7d4f); }
  .sc-grid__key--out { background: var(--alarm); }
  /* the headline rank numbers */
  .sc-rank__stats { display: grid; gap: var(--space-4); }
  .sc-rank__stat { padding: var(--space-4) var(--space-5); border-radius: var(--radius-md); border-left: var(--rule-thick) solid var(--line); background: var(--bg-raised); }
  .sc-rank__stat--fail { border-left-color: var(--alarm); }
  .sc-rank__stat--warn { border-left-color: var(--accent); }
  .sc-rank__stat--pass { border-left-color: var(--ok, #2e7d4f); }
  .sc-rank__num { display: block; font-family: var(--font-display); font-weight: var(--fw-display); font-size: var(--fs-h2); line-height: 1; color: var(--ink); }
  .sc-rank__stat--fail .sc-rank__num { color: var(--alarm); }
  .sc-rank__cap { display: block; margin-top: var(--space-2); font-size: var(--fs-body-sm); color: var(--ink-70); }
  .sc-rank__above { margin-top: var(--space-5); font-size: var(--fs-body-sm); color: var(--ink-70); line-height: 1.55; }
  .sc-rank__abovelabel { font-weight: var(--fw-body-bold); color: var(--ink); }

  /* "More info" prompt + bouncing down arrow pointing to the video below */
  .sc-more { margin-top: var(--space-12); text-align: center; }
  .sc-more__label { font-family: var(--font-body); font-size: var(--fs-eyebrow); font-weight: var(--fw-body-semi); text-transform: uppercase; letter-spacing: var(--tracking-caps); color: var(--ink-50); }
  .sc-more__arrow { display: block; margin-top: var(--space-3); font-size: 1.75rem; line-height: 1; color: var(--accent); animation: sc-bounce 1.6s ease-in-out infinite; }
  @keyframes sc-bounce { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(6px); } }

  /* keep the prose at a readable measure even though the grid runs full width */
  .sc-verdict__sub, .sc-section__sub, .sc-doing { max-width: 52rem; }
  .sc-math { margin-top: var(--space-10); max-width: 52rem; font-family: var(--font-serif); font-size: var(--fs-bodyL); line-height: 1.6; color: var(--ink); padding: var(--space-5); border-left: var(--rule-thick) solid var(--accent); background: var(--bg-raised); }

  /* result — escalation (the point) */
