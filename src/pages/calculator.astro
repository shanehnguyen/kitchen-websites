---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButton from '../components/CTAButton.astro';
import StickyMobileCTA from '../components/StickyMobileCTA.astro';
---
<BaseLayout
  title="Lost Referral Calculator"
  description="See what your referrals are quietly costing you when they check you on Google. Three numbers, honest math, no black box."
  ogImage="/assets/images/og-cover.svg"
>
  <section class="section calc-hero">
    <div class="container">
      <p class="eyebrow">The Lost Referral Calculator</p>
      <h1 class="calc-hero__h1">Your referrals are checking Google. Some of them are calling someone else.</h1>
      <p class="lede calc-hero__lede">
        Three numbers off the top of your head. We’ll show you — with the math in plain English — what that leak
        is worth in a year. We pick a deliberately low percentage; the real number is usually worse.
      </p>

      <div class="calc">
        <form class="calc__inputs" data-calc>
          <div class="field">
            <label for="referrals">Referrals you get a month</label>
            <input id="referrals" name="referrals" type="number" inputmode="numeric" min="0" value="4" />
          </div>
          <div class="field">
            <label for="jobValue">Your average job value</label>
            <input id="jobValue" name="jobValue" type="number" inputmode="numeric" min="0" step="500" value="24000" />
          </div>
          <div class="field">
            <label for="reviews">Your Google review count</label>
            <input id="reviews" name="reviews" type="number" inputmode="numeric" min="0" value="8" />
          </div>
        </form>

        <div class="calc__result">
          <p class="calc__result-label">That’s roughly what you’re leaking a year:</p>
          <p class="calc__leak mono" data-calc-leak>$0</p>
          <p class="calc__math" data-calc-math></p>
          <p class="calc__fallback" data-calc-fallback hidden>
            Even a “small” leak is a job a year you already earned and gave away — and the businesses beating you
            compound this every single month. The point isn’t the size. It’s that it’s happening at all.
          </p>
          <p class="calc__assumptions mono">
            Conservative by design: we only count referrals who defect after checking your Google presence. No
            invented “lead” numbers, no magic multipliers.
          </p>
          <CTAButton
            href="/book"
            label="That’s the leak — let’s plug it"
            derisk="A free 30-minute session: where your jobs are leaking, and the fix in writing. Yours to keep."
            event="CalcToBook"
            size="lg"
          />
        </div>
      </div>
    </div>
  </section>

  <StickyMobileCTA href="/book" label="Book a free session" event="CalcStickyToBook" />
</BaseLayout>

<script>
  import { init } from '../islands/calculator/calc.ts';
  init();
</script>

<style>
  .calc-hero__h1 { margin-top: var(--space-3); max-width: 18ch; }
  .calc-hero__lede { margin-top: var(--space-4); max-width: 60ch; }
  .calc {
    margin-top: var(--space-10);
    display: grid; grid-template-columns: 1fr; gap: var(--space-8);
    align-items: start;
  }
  @media (min-width: 56em) { .calc { grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr); gap: var(--space-12); } }

  .calc__inputs {
    display: grid; gap: var(--space-5);
    padding: var(--space-6);
    background: var(--porcelain-soft);
    border: var(--rule-width) solid var(--rule);
    border-top: var(--rule-thick) solid var(--brass);
    border-radius: var(--radius-sm);
  }
  @media (min-width: 56em) { .calc__inputs { position: sticky; top: var(--space-8); } }

  /* Result rendered in the signature document style */
  .calc__result {
    border: var(--rule-thick) solid var(--cabinet);
    border-radius: var(--radius-sm);
    box-shadow: 6px 6px 0 var(--rule-soft);
    padding: var(--space-8) var(--space-6);
    background: #fff;
  }
  .calc__result-label { font-family: var(--font-mono); font-size: var(--fs-caption); text-transform: uppercase; letter-spacing: var(--tracking-caps); color: var(--ink-50); }
  .calc__leak {
    font-family: var(--font-display);
    font-size: clamp(3rem, 9vw, 6rem);
    line-height: 0.9; letter-spacing: -0.02em;
    color: var(--alarm);
    margin-block: var(--space-2) var(--space-5);
  }
  .calc__math { font-size: var(--fs-body); line-height: 1.6; color: var(--ink-70); }
  .calc__math :global(strong) { color: var(--ink); font-variant-numeric: tabular-nums; }
  .calc__fallback {
    margin-top: var(--space-4); padding: var(--space-4);
    border-left: var(--rule-thick) solid var(--brass);
    background: var(--porcelain-soft); color: var(--ink-70); font-size: var(--fs-body-sm);
  }
  .calc__assumptions { margin-top: var(--space-5); font-size: var(--fs-caption); color: var(--ink-50); }
  .calc__result .cta-block { margin-top: var(--space-6); }
</style>
