---
/* /pulse — PRIVATE booking-funnel dashboard. Token-gated (PULSE_TOKEN, checked
   server-side in /api/pulse). Shows the funnel with drop-off at each step and a
   live list of recent visitors + how far each got. noindex; not linked anywhere. */
import BareLayout from '../layouts/BareLayout.astro';
---
<BareLayout
  title="Booking pulse"
  description="Private booking-funnel dashboard."
  noindex={true}
  legalFooter={false}
>
  <section class="pl">
    <div class="pl-wrap">
      <header class="pl-head">
        <h1 class="pl-title">Booking&nbsp;pulse</h1>
        <div class="pl-meta">
          <span data-pl-redis class="pl-redis" hidden></span>
          <span data-pl-updated class="pl-updated"></span>
          <button type="button" class="pl-btn" data-pl-refresh>Refresh</button>
          <button type="button" class="pl-btn pl-btn--ghost" data-pl-signout hidden>Sign out</button>
        </div>
      </header>

      <!-- token gate -->
      <form class="pl-gate" data-pl-gate hidden>
        <label class="pl-gate__label" for="pl-token">Dashboard password</label>
        <div class="pl-gate__row">
          <input class="pl-gate__input" id="pl-token" type="password" autocomplete="off" placeholder="PULSE_TOKEN" />
          <button type="submit" class="pl-btn">Open</button>
        </div>
        <p class="pl-gate__err" data-pl-gate-err hidden></p>
      </form>

      <div data-pl-body hidden>
        <!-- funnel -->
        <div class="pl-card">
          <h2 class="pl-h2">Funnel <span class="pl-dim" data-pl-window></span></h2>
          <div class="pl-funnel" data-pl-funnel></div>
        </div>

        <!-- which CTA / source converts -->
        <div class="pl-card">
          <h2 class="pl-h2">By CTA / source <span class="pl-dim">· visitors → booked</span></h2>
          <div class="pl-sources" data-pl-sources></div>
        </div>

        <!-- recent visitors -->
        <div class="pl-card">
          <h2 class="pl-h2">Recent visitors <span class="pl-dim" data-pl-count></span></h2>
          <div class="pl-list" data-pl-list></div>
        </div>
      </div>

      <p class="pl-note" data-pl-note hidden></p>
    </div>
  </section>
</BareLayout>

<script>
  const TOKEN_KEY = 'kw_pulse_token';
  const $ = (s: string) => document.querySelector(s) as HTMLElement;
  const gate = $('[data-pl-gate]');
  const gateErr = $('[data-pl-gate-err]');
  const body = $('[data-pl-body]');
  const note = $('[data-pl-note]');
  const funnelEl = $('[data-pl-funnel]');
  const sourcesEl = $('[data-pl-sources]');
  const listEl = $('[data-pl-list]');
  const updatedEl = $('[data-pl-updated]');
  const redisEl = $('[data-pl-redis]');
  const countEl = $('[data-pl-count]');
  const windowEl = $('[data-pl-window]');
  const signout = $('[data-pl-signout]') as HTMLButtonElement;

  const REDIS_STATE: Record<string, { label: string; cls: string }> = {
    connected: { label: '● database connected', cls: 'is-ok' },
    unreachable: { label: '● database not reachable', cls: 'is-bad' },
    'not-configured': { label: '● database not configured', cls: 'is-bad' },
  };

  const STAGE_TONE: Record<string, string> = {
    landed: 'cool', type: 'cool', jobs: 'mid', details: 'warm', calendar: 'good', booked: 'good',
  };

  const esc = (s: string) => (s || '').replace(/[&<>"]/g, (c) =>
    ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c] as string));

  function ago(ts: number): string {
    const s = Math.max(0, Math.round((Date.now() - ts) / 1000));
    if (s < 60) return `${s}s ago`;
    const m = Math.round(s / 60);
    if (m < 60) return `${m}m ago`;
    const h = Math.round(m / 60);
    if (h < 24) return `${h}h ago`;
    return `${Math.round(h / 24)}d ago`;
  }
  function dwell(j: any): string {
    const s = Math.max(0, Math.round(((j.updatedAt || 0) - (j.landedAt || 0)) / 1000));
    return s < 60 ? `${s}s` : `${Math.round(s / 60)}m`;
  }

  function token(): string {
    try { return localStorage.getItem(TOKEN_KEY) || ''; } catch { return ''; }
  }
  function setToken(t: string) {
    try { if (t) localStorage.setItem(TOKEN_KEY, t); else localStorage.removeItem(TOKEN_KEY); } catch {}
  }

  function showGate(msg?: string) {
    gate.hidden = false;
    body.hidden = true;
    signout.hidden = true;
    if (msg) { gateErr.textContent = msg; gateErr.hidden = false; }
  }

  function renderSources(sources: any[]) {
    if (!sources.length) { sourcesEl.innerHTML = '<p class="pl-empty">No tagged traffic yet.</p>'; return; }
    sourcesEl.innerHTML =
      '<table class="pl-src"><thead><tr><th>Source</th><th>Visitors</th><th>Booked</th><th>Rate</th></tr></thead><tbody>' +
      sources.map((s) =>
        `<tr><td>${esc(s.source)}</td><td>${s.total}</td><td>${s.booked}</td><td class="${s.booked ? 'is-good' : ''}">${s.rate}%</td></tr>`
      ).join('') +
      '</tbody></table>';
  }

  function renderFunnel(funnel: any[]) {
    const top = funnel.length ? funnel[0].count : 0;
    funnelEl.innerHTML = funnel.map((row, i) => {
      const prev = i > 0 ? funnel[i - 1].count : row.count;
      const pctOfTop = top ? Math.round((row.count / top) * 100) : 0;
      const dropped = prev - row.count;
      const dropPct = prev ? Math.round((dropped / prev) * 100) : 0;
      const tone = STAGE_TONE[row.stage] || 'cool';
      return `
        <div class="pl-frow">
          <div class="pl-fmeta">
            <span class="pl-flabel">${esc(row.label)}</span>
            <span class="pl-fnum">${row.count}</span>
          </div>
          <div class="pl-fbar"><span class="pl-ffill pl-tone--${tone}" style="width:${Math.max(pctOfTop, row.count ? 3 : 0)}%"></span></div>
          <div class="pl-fdrop">${i > 0 && dropped > 0 ? `↓ ${dropped} left here (${dropPct}%)` : (i === 0 ? '' : '—')}</div>
        </div>`;
    }).join('');
  }

  function renderList(journeys: any[]) {
    countEl.textContent = journeys.length ? `· ${journeys.length}` : '';
    if (!journeys.length) {
      listEl.innerHTML = '<p class="pl-empty">No visitors in the last 7 days yet.</p>';
      return;
    }
    // repeat-visit counts by IP — so one person's reloads read differently from many people
    const ipCounts: Record<string, number> = {};
    journeys.forEach((j) => { if (j.ip) ipCounts[j.ip] = (ipCounts[j.ip] || 0) + 1; });
    listEl.innerHTML = journeys.map((j) => {
      const tone = STAGE_TONE[j.stage] || 'cool';
      const who = j.businessName || j.businessType || 'Anonymous';
      const detail = [j.businessType, j.customers, j.jobs && `${j.jobs}/mo`].filter(Boolean).join(' · ');
      const entry = entryOf(j);
      const dev = deviceLabel(j.ua || '');
      const repeat = j.ip && ipCounts[j.ip] > 1 ? ` · seen ${ipCounts[j.ip]}×` : '';
      const refUrl = j.referrer && entry.kind !== 'ref' ? j.referrer : '';
      return `
        <div class="pl-row">
          <div class="pl-row__main">
            <span class="pl-who">${esc(who)}</span>
            <span class="pl-badge pl-tone--${tone}">${esc(stageLabel(j.stage))}</span>
          </div>
          <div class="pl-entry pl-entry--${entry.kind}">${esc(entry.label)}</div>
          <div class="pl-row__sub">
            ${detail ? `<span>${esc(detail)}</span>` : ''}
            ${j.website ? `<span>${esc(j.website)}</span>` : ''}
          </div>
          <div class="pl-row__foot">
            ${refUrl ? `<span title="referring page">ref: ${esc(refUrl)}</span>` : ''}
            ${dev ? `<span>${esc(dev)}</span>` : ''}
            <span>${dwell(j)} on page</span>
            <span>${ago(j.updatedAt || 0)}</span>
            ${j.ip ? `<span title="IP address" class="pl-ip">${esc(j.ip)}${repeat}</span>` : ''}
          </div>
        </div>`;
    }).join('');
  }

  const STAGE_LABELS: Record<string, string> = {
    landed: 'Landed', type: 'Picked type', jobs: 'Jobs answered',
    details: 'On business', calendar: 'At calendar', booked: 'Booked',
  };
  const stageLabel = (s: string) => STAGE_LABELS[s] || s;

  // Turn a CTA event into a readable label — handles "Dfy:HeroToBook" →
  // "Done-for-you · Hero" and colon-less homepage events "ReelToBook" → "Reel".
  const CTA_PAGES: Record<string, string> = { dfy: 'Done-for-you', home: 'Homepage', about: 'About', web: 'Websites', websites: 'Websites', sc: 'Scorecard', scorecard: 'Scorecard', nav: 'Nav bar' };
  function prettyCta(s: string): string {
    let page = '', locRaw = s;
    const m = s.match(/^([A-Za-z]+):(.+)$/);
    if (m) { page = CTA_PAGES[m[1].toLowerCase()] || m[1]; locRaw = m[2]; }
    let loc = locRaw.replace(/ToBook$/i, '');
    loc = loc.replace(/([a-z])([A-Z])/g, '$1 $2'); // camelCase → words
    if (/^faq$/i.test(loc)) loc = 'FAQ';
    if (!loc || /^book$/i.test(loc)) return page || 'button';
    return page ? page + ' · ' + loc : loc;
  }
  // Classify how a visitor arrived: on-site CTA click, paid ad, referral, or direct.
  function entryOf(j: any): { kind: string; label: string } {
    const s = j.source || '';
    const isCta = /:/.test(s) ? /^[A-Za-z]+:[A-Za-z]+$/.test(s) : /ToBook$/i.test(s);
    if (s && isCta) return { kind: 'cta', label: 'clicked · ' + prettyCta(s) };
    if (s) return { kind: 'ad', label: 'ad · ' + s };
    if (j.referrer) {
      let d = j.referrer;
      try { d = new URL(j.referrer).hostname.replace(/^www\./, ''); } catch {}
      return { kind: 'ref', label: 'referral · ' + d };
    }
    return { kind: 'direct', label: 'direct — typed the URL or no referrer' };
  }

  function deviceLabel(ua: string): string {
    if (!ua) return '';
    const mobile = /Mobi|Android|iPhone|iPad|iPod/i.test(ua);
    let b = '';
    if (/Edg\//i.test(ua)) b = 'Edge';
    else if (/OPR\//i.test(ua) || /Opera/i.test(ua)) b = 'Opera';
    else if (/Chrome\//i.test(ua)) b = 'Chrome';
    else if (/Firefox\//i.test(ua)) b = 'Firefox';
    else if (/Safari\//i.test(ua)) b = 'Safari';
    return (mobile ? 'Mobile' : 'Desktop') + (b ? ' · ' + b : '');
  }

  async function load() {
    const t = token();
    if (!t) { showGate(); return; }
    let r: Response;
    try {
      r = await fetch(`/api/pulse?token=${encodeURIComponent(t)}`, { cache: 'no-store' });
    } catch {
      note.textContent = 'Could not reach the server. Retrying on next refresh.';
      note.hidden = false;
      return;
    }
    if (r.status === 401) { setToken(''); showGate('That password didn’t work. Try again.'); return; }
    if (r.status === 503) {
      gate.hidden = true; body.hidden = true; signout.hidden = true;
      note.innerHTML = 'The dashboard is off. Set a <code>PULSE_TOKEN</code> environment variable in Vercel, redeploy, then reload this page.';
      note.hidden = false;
      return;
    }
    if (!r.ok) { note.textContent = `Server error (${r.status}).`; note.hidden = false; return; }

    const data = await r.json();
    note.hidden = true;
    gate.hidden = true;
    body.hidden = false;
    signout.hidden = false;
    const j = Array.isArray(data.journeys) ? data.journeys : [];
    renderFunnel(Array.isArray(data.funnel) ? data.funnel : []);
    renderSources(Array.isArray(data.sources) ? data.sources : []);
    renderList(j);
    windowEl.textContent = '· last 7 days';
    updatedEl.textContent = `Updated ${new Date().toLocaleTimeString()}`;
    // database health — so an all-zero board can't hide a dead/misconfigured DB
    const rs = REDIS_STATE[data.redisStatus as string];
    if (rs) {
      redisEl.textContent = rs.label;
      redisEl.className = `pl-redis ${rs.cls}`;
      redisEl.hidden = false;
      if (data.redisStatus !== 'connected') {
        note.innerHTML = 'The booking database isn’t connected, so nothing can be recorded. Add an Upstash Redis in Vercel (Storage), set <code>UPSTASH_REDIS_REST_URL</code> + <code>UPSTASH_REDIS_REST_TOKEN</code>, and redeploy.';
        note.hidden = false;
      }
    } else {
      redisEl.hidden = true;
    }
  }

  // token gate submit
  gate.addEventListener('submit', (e) => {
    e.preventDefault();
    const inp = document.getElementById('pl-token') as HTMLInputElement;
    const val = (inp.value || '').trim();
    if (!val) return;
    setToken(val);
    gateErr.hidden = true;
    load();
  });
  $('[data-pl-refresh]').addEventListener('click', () => load());
  signout.addEventListener('click', () => { setToken(''); showGate(); });

  // allow ?token=... in the URL for a one-tap bookmark
  const urlToken = new URLSearchParams(location.search).get('token');
  if (urlToken) { setToken(urlToken); history.replaceState(null, '', location.pathname); }

  load();
  setInterval(() => { if (!body.hidden) load(); }, 20000); // live-ish refresh
</script>

<style>
  .pl { padding: var(--space-8) 0 var(--space-16); min-height: 70vh; }
  .pl-wrap { max-width: 60rem; margin-inline: auto; padding-inline: var(--gutter); }
  .pl-head { display: flex; align-items: baseline; justify-content: space-between; flex-wrap: wrap; gap: var(--space-3); }
  .pl-title { font-size: var(--fs-h3); }
  .pl-meta { display: flex; align-items: center; gap: var(--space-3); }
  .pl-updated { font-size: var(--fs-caption); color: var(--ink-50); font-family: var(--font-mono); }
  .pl-redis { font-size: var(--fs-caption); font-family: var(--font-mono); font-weight: var(--fw-body-semi); }
  .pl-redis.is-ok { color: #3F7F4F; }
  .pl-redis.is-bad { color: #C0392B; }
  .pl-btn { font-family: var(--font-body); font-size: var(--fs-body-sm); font-weight: var(--fw-body-semi); padding: var(--space-2) var(--space-4); border: var(--rule-thick) solid var(--line); border-radius: var(--radius-sm); background: #fff; color: var(--ink); cursor: pointer; }
  .pl-btn:hover { border-color: var(--ink); }
  .pl-btn--ghost { border-color: transparent; color: var(--ink-50); }

  .pl-gate { margin-top: var(--space-8); max-width: 24rem; }
  .pl-gate__label { display: block; font-size: var(--fs-body-sm); font-weight: var(--fw-body-semi); color: var(--ink-70); margin-bottom: var(--space-2); }
  .pl-gate__row { display: flex; gap: var(--space-2); }
  .pl-gate__input { flex: 1; font-family: var(--font-mono); font-size: var(--fs-body); padding: var(--space-3); border: var(--rule-thick) solid var(--line); border-radius: var(--radius-sm); background: #fff; color: var(--ink); }
  .pl-gate__err { margin-top: var(--space-3); font-size: var(--fs-body-sm); color: var(--warn); }

  .pl-card { margin-top: var(--space-6); padding: var(--space-6); border: 1px solid var(--line); border-radius: var(--radius-md); background: color-mix(in srgb, var(--paper, #fff) 100%, transparent); }
  .pl-h2 { font-size: var(--fs-h5, var(--fs-body)); font-weight: var(--fw-body-semi); }
  .pl-dim { color: var(--ink-50); font-weight: var(--fw-body); font-size: var(--fs-caption); font-family: var(--font-mono); }

  /* funnel */
  .pl-funnel { margin-top: var(--space-5); display: grid; gap: var(--space-4); }
  .pl-frow { display: grid; grid-template-columns: 1fr; gap: var(--space-2); }
  .pl-fmeta { display: flex; justify-content: space-between; align-items: baseline; }
  .pl-flabel { font-size: var(--fs-body-sm); color: var(--ink-70); }
  .pl-fnum { font-family: var(--font-mono); font-size: var(--fs-body); font-weight: var(--fw-body-semi); }
  .pl-fbar { height: 12px; background: var(--line); border-radius: 999px; overflow: hidden; }
  .pl-ffill { display: block; height: 100%; border-radius: 999px; transition: width 400ms cubic-bezier(.2,.7,.2,1); }
  .pl-fdrop { font-size: var(--fs-caption); color: var(--ink-50); font-family: var(--font-mono); min-height: 1em; }

  .pl-tone--cool { background: #6b8cae; }
  .pl-tone--mid  { background: #A78B4F; }
  .pl-tone--warm { background: #C9803E; }
  .pl-tone--good { background: #3F7F4F; }

  /* by-CTA table */
  .pl-src { width: 100%; margin-top: var(--space-4); border-collapse: collapse; font-family: var(--font-mono); font-size: var(--fs-body-sm); }
  .pl-src th, .pl-src td { text-align: right; padding: var(--space-2) var(--space-3); border-bottom: 1px solid var(--line); }
  .pl-src th:first-child, .pl-src td:first-child { text-align: left; }
  .pl-src thead th { font-size: var(--fs-caption); text-transform: uppercase; letter-spacing: 0.04em; color: var(--ink-50); font-weight: var(--fw-body-semi); }
  .pl-src td.is-good { color: #3F7F4F; font-weight: var(--fw-body-semi); }

  /* list */
  .pl-list { margin-top: var(--space-4); display: grid; gap: var(--space-3); }
  .pl-row { padding: var(--space-4); border: 1px solid var(--line); border-radius: var(--radius-sm); }
  .pl-row__main { display: flex; align-items: center; gap: var(--space-3); flex-wrap: wrap; }
  /* prominent "how they arrived" line */
  .pl-entry { margin-top: var(--space-2); font-family: var(--font-mono); font-size: var(--fs-body-sm); font-weight: var(--fw-body-semi); }
  .pl-entry--cta { color: #3F7F4F; }
  .pl-entry--ad { color: #A9722B; }
  .pl-entry--ref { color: var(--ink-70); }
  .pl-entry--direct { color: var(--ink-50); font-weight: var(--fw-body); }
  .pl-who { font-weight: var(--fw-body-semi); }
  .pl-badge { font-size: var(--fs-caption); font-weight: var(--fw-body-semi); color: #fff; padding: 2px 8px; border-radius: 999px; }
  .pl-row__sub { margin-top: var(--space-2); display: flex; flex-wrap: wrap; gap: var(--space-3); font-size: var(--fs-body-sm); color: var(--ink-70); }
  .pl-row__gripe { margin-top: var(--space-2); font-style: italic; font-size: var(--fs-body-sm); color: var(--ink); font-family: var(--font-serif); }
  .pl-row__foot { margin-top: var(--space-3); display: flex; flex-wrap: wrap; gap: var(--space-4); font-size: var(--fs-caption); color: var(--ink-50); font-family: var(--font-mono); }
  .pl-empty { color: var(--ink-50); font-size: var(--fs-body-sm); }

  .pl-note { margin-top: var(--space-6); font-size: var(--fs-body-sm); color: var(--ink-70); }
  .pl-note code { font-family: var(--font-mono); background: var(--line); padding: 1px 5px; border-radius: 4px; }
</style>
